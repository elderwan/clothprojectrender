{
  "info": {
    "name": "Clothes Shop API",
    "_postman_id": "d4ab5d44-2f1f-4f3d-96b8-3d93d4f7f7a9",
    "description": "Collection for all routes in this project. Use cookie jar to keep session after login.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Client - Public",
      "item": [
        {
          "name": "Home",
          "request": { "method": "GET", "url": "{{baseUrl}}/" }
        },
        {
          "name": "Show Login",
          "request": { "method": "GET", "url": "{{baseUrl}}/login" }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "email", "value": "{{clientEmail}}", "type": "text" },
                { "key": "password", "value": "{{clientPassword}}", "type": "text" },
                { "key": "redirect", "value": "/", "type": "text" }
              ]
            },
            "url": "{{baseUrl}}/login"
          }
        },
        {
          "name": "Show Register",
          "request": { "method": "GET", "url": "{{baseUrl}}/register" }
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "full_name", "value": "{{newUserName}}", "type": "text" },
                { "key": "email", "value": "{{newUserEmail}}", "type": "text" },
                { "key": "password", "value": "{{newUserPassword}}", "type": "text" },
                { "key": "phone", "value": "0123456789", "type": "text" }
              ]
            },
            "url": "{{baseUrl}}/register"
          }
        },
        {
          "name": "Logout",
          "request": { "method": "GET", "url": "{{baseUrl}}/logout" }
        },
        {
          "name": "List Products",
          "request": { "method": "GET", "url": "{{baseUrl}}/products?category={{categorySlug}}" }
        },
        {
          "name": "Product Detail",
          "request": { "method": "GET", "url": "{{baseUrl}}/products/{{productId}}" }
        }
      ]
    },
    {
      "name": "Client - Cart",
      "item": [
        {
          "name": "Show Cart",
          "request": { "method": "GET", "url": "{{baseUrl}}/cart" }
        },
        {
          "name": "Add To Cart",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "product_id", "value": "{{productId}}", "type": "text" },
                { "key": "quantity", "value": "1", "type": "text" },
                { "key": "size", "value": "M", "type": "text" }
              ]
            },
            "url": "{{baseUrl}}/cart/add"
          }
        },
        {
          "name": "Update Cart Item Qty",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "id", "value": "{{cartItemId}}", "type": "text" },
                { "key": "quantity", "value": "2", "type": "text" }
              ]
            },
            "url": "{{baseUrl}}/cart/update"
          }
        },
        {
          "name": "Remove Cart Item",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/cart/remove/{{cartItemId}}"
          }
        }
      ]
    },
    {
      "name": "Client - Orders",
      "item": [
        {
          "name": "Place Order",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [{ "key": "address_id", "value": "{{addressId}}", "type": "text" }]
            },
            "url": "{{baseUrl}}/orders"
          }
        },
        {
          "name": "Simulate Payment (JSON)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [{ "key": "result", "value": "success", "type": "text" }]
            },
            "url": "{{baseUrl}}/orders/{{orderId}}/simulate-payment"
          }
        },
        {
          "name": "Order Confirm",
          "request": { "method": "GET", "url": "{{baseUrl}}/order-confirm/{{orderId}}" }
        },
        {
          "name": "Order History",
          "request": { "method": "GET", "url": "{{baseUrl}}/orders" }
        },
        {
          "name": "Order Detail",
          "request": { "method": "GET", "url": "{{baseUrl}}/orders/{{orderId}}" }
        }
      ]
    },
    {
      "name": "Client - Profile & Address",
      "item": [
        {
          "name": "Show Profile",
          "request": { "method": "GET", "url": "{{baseUrl}}/profile" }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "full_name", "value": "{{clientName}}", "type": "text" },
                { "key": "phone", "value": "0123456789", "type": "text" },
                { "key": "password", "value": "", "type": "text" },
                { "key": "confirm_password", "value": "", "type": "text" }
              ]
            },
            "url": "{{baseUrl}}/profile"
          }
        },
        {
          "name": "Add Address",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "label", "value": "Home", "type": "text" },
                { "key": "full_name", "value": "{{clientName}}", "type": "text" },
                { "key": "phone", "value": "0123456789", "type": "text" },
                { "key": "address_line1", "value": "123 Main Street", "type": "text" },
                { "key": "address_line2", "value": "Unit 10", "type": "text" },
                { "key": "city", "value": "Chiang Mai", "type": "text" },
                { "key": "state", "value": "Chiang Mai", "type": "text" },
                { "key": "postal_code", "value": "50000", "type": "text" },
                { "key": "country", "value": "TH", "type": "text" },
                { "key": "is_default", "value": "on", "type": "text" }
              ]
            },
            "url": "{{baseUrl}}/addresses"
          }
        },
        {
          "name": "Edit Address",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "label", "value": "Office", "type": "text" },
                { "key": "full_name", "value": "{{clientName}}", "type": "text" },
                { "key": "phone", "value": "0123456789", "type": "text" },
                { "key": "address_line1", "value": "456 Business Road", "type": "text" },
                { "key": "address_line2", "value": "Floor 2", "type": "text" },
                { "key": "city", "value": "Chiang Mai", "type": "text" },
                { "key": "state", "value": "Chiang Mai", "type": "text" },
                { "key": "postal_code", "value": "50000", "type": "text" },
                { "key": "country", "value": "TH", "type": "text" }
              ]
            },
            "url": "{{baseUrl}}/addresses/{{addressId}}/edit"
          }
        },
        {
          "name": "Delete Address",
          "request": { "method": "POST", "url": "{{baseUrl}}/addresses/{{addressId}}/delete" }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Show Admin Login",
          "request": { "method": "GET", "url": "{{baseUrl}}/admin/login" }
        },
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "email", "value": "{{adminEmail}}", "type": "text" },
                { "key": "password", "value": "{{adminPassword}}", "type": "text" }
              ]
            },
            "url": "{{baseUrl}}/admin/login"
          }
        },
        {
          "name": "Admin Logout",
          "request": { "method": "GET", "url": "{{baseUrl}}/admin/logout" }
        },
        {
          "name": "Dashboard",
          "request": { "method": "GET", "url": "{{baseUrl}}/admin/" }
        },
        {
          "name": "Products - List",
          "request": { "method": "GET", "url": "{{baseUrl}}/admin/products" }
        },
        {
          "name": "Products - Show Add",
          "request": { "method": "GET", "url": "{{baseUrl}}/admin/products/add" }
        },
        {
          "name": "Upload Product Image (Cloudinary)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"file\": \"{{imageDataUri}}\"\n}"
            },
            "url": "{{baseUrl}}/admin/uploads/product-image"
          }
        },
        {
          "name": "Products - Add",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "name", "value": "New Product", "type": "text" },
                { "key": "description", "value": "Sample description", "type": "text" },
                { "key": "price", "value": "199.00", "type": "text" },
                { "key": "category_id", "value": "{{categoryId}}", "type": "text" },
                { "key": "stock_quantity", "value": "10", "type": "text" },
                { "key": "image_urls", "value": "https://example.com/a.jpg\nhttps://example.com/b.jpg", "type": "text" }
              ]
            },
            "url": "{{baseUrl}}/admin/products/add"
          }
        },
        {
          "name": "Products - Show Edit",
          "request": { "method": "GET", "url": "{{baseUrl}}/admin/products/{{productId}}/edit" }
        },
        {
          "name": "Products - Edit",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "name", "value": "Updated Product", "type": "text" },
                { "key": "description", "value": "Updated description", "type": "text" },
                { "key": "price", "value": "249.00", "type": "text" },
                { "key": "category_id", "value": "{{categoryId}}", "type": "text" },
                { "key": "stock_quantity", "value": "20", "type": "text" },
                { "key": "image_urls", "value": "https://example.com/updated.jpg", "type": "text" }
              ]
            },
            "url": "{{baseUrl}}/admin/products/{{productId}}/edit"
          }
        },
        {
          "name": "Products - Delete",
          "request": { "method": "POST", "url": "{{baseUrl}}/admin/products/{{productId}}/delete" }
        },
        {
          "name": "Orders - List",
          "request": { "method": "GET", "url": "{{baseUrl}}/admin/orders?status={{orderStatus}}" }
        },
        {
          "name": "Orders - Detail",
          "request": { "method": "GET", "url": "{{baseUrl}}/admin/orders/{{orderId}}" }
        },
        {
          "name": "Orders - Update Status",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [{ "key": "status", "value": "processing", "type": "text" }]
            },
            "url": "{{baseUrl}}/admin/orders/{{orderId}}/status"
          }
        },
        {
          "name": "Customers - List",
          "request": { "method": "GET", "url": "{{baseUrl}}/admin/customers" }
        },
        {
          "name": "Customers - Detail",
          "request": { "method": "GET", "url": "{{baseUrl}}/admin/customers/{{userId}}" }
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "clientEmail", "value": "client@example.com" },
    { "key": "clientPassword", "value": "password123" },
    { "key": "clientName", "value": "Client User" },
    { "key": "newUserName", "value": "New User" },
    { "key": "newUserEmail", "value": "newuser@example.com" },
    { "key": "newUserPassword", "value": "password123" },
    { "key": "adminEmail", "value": "admin@maison.com" },
    { "key": "adminPassword", "value": "admin123" },
    { "key": "productId", "value": "" },
    { "key": "cartItemId", "value": "" },
    { "key": "orderId", "value": "" },
    { "key": "addressId", "value": "" },
    { "key": "categoryId", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "categorySlug", "value": "" },
    { "key": "orderStatus", "value": "all" }
    ,
    { "key": "imageDataUri", "value": "data:image/png;base64,REPLACE_WITH_BASE64" }
  ]
}
