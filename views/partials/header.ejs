<header class="relative border-b border-[#e6e0d8] bg-[#fcfcfa]">
  <div class="mx-auto h-[92px] max-w-[1440px] px-4 lg:px-[140px]">
    <a href="/" class="absolute left-1/2 top-[24px] -translate-x-1/2 font-serif text-[34px] font-normal tracking-[0.08em] leading-none lg:text-[42px]">MAISON</a>

    <nav class="absolute left-[140px] top-[38px] hidden items-center gap-[34px] lg:flex">
      <a href="/products?audience=women" class="text-[13px] font-semibold tracking-[0.14em] leading-none text-black hover:text-zinc-600">WOMEN</a>
      <a href="/products?audience=men" class="text-[13px] font-semibold tracking-[0.14em] leading-none text-black hover:text-zinc-600">MEN</a>
      <a href="/products?audience=kids" class="text-[13px] font-semibold tracking-[0.14em] leading-none text-black hover:text-zinc-600">KIDS</a>
    </nav>

    <nav class="absolute right-[140px] top-[38px] hidden items-center gap-[34px] lg:flex">
      <a href="/products" class="text-[13px] font-normal leading-none text-black hover:text-zinc-600">Search</a>
      <% if (user) { %>
        <a href="/profile" class="text-[13px] font-normal leading-none text-black hover:text-zinc-600">Account</a>
      <% } else { %>
        <a href="/login" class="text-[13px] font-normal leading-none text-black hover:text-zinc-600">Account</a>
      <% } %>
      <a href="/cart" class="text-[13px] font-normal leading-none text-black hover:text-zinc-600">
        Cart<% if (cartCount && cartCount > 0) { %> (<%= cartCount %>)<% } %>
      </a>
    </nav>

    <!-- mobile menu button -->
    <button id="nav-toggle" class="absolute left-4 top-1/2 -translate-y-1/2 lg:hidden" aria-label="Toggle navigation">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <nav id="main-nav" class="hidden absolute z-20 top-full left-0 w-full border-b border-[#e6e0d8] bg-[#fcfcfa] p-4 lg:hidden">
      <div class="flex flex-col gap-4 text-[13px]">
        <a href="/products?audience=women" class="font-bold hover:text-zinc-600">WOMEN</a>
        <a href="/products?audience=men" class="font-bold hover:text-zinc-600">MEN</a>
        <a href="/products?audience=kids" class="font-bold hover:text-zinc-600">KIDS</a>
        <a href="/products" class="hover:text-zinc-600">Search</a>
        <% if (user) { %>
          <a href="/profile" class="hover:text-zinc-600">Account</a>
        <% } else { %>
          <a href="/login" class="hover:text-zinc-600">Account</a>
        <% } %>
        <a href="/cart" class="hover:text-zinc-600">Cart<% if (cartCount && cartCount > 0) { %> (<%= cartCount %>)<% } %></a>
      </div>
    </nav>
  </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var toggle = document.getElementById('nav-toggle');
    var nav = document.getElementById('main-nav');
    if (toggle && nav) {
      toggle.addEventListener('click', function () {
        nav.classList.toggle('hidden');
      });
    }    // close dropdown when a link is tapped (mobile only)
    if (nav) {
      nav.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          if (window.getComputedStyle(toggle).display !== 'none') {
            nav.classList.add('hidden');
          }
        });
      });
    }
  });
</script>
