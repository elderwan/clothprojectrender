<script>
  (function () {
    if (window.ClientModal) return;

    const root = document.createElement('div');
    root.id = 'client-modal-root';
    root.className = 'fixed inset-0 z-[110] hidden items-center justify-center bg-black/45 p-4';
    root.innerHTML = `
      <div class="w-full max-w-[420px] border border-[#e0e0e0] bg-white shadow-[0_24px_80px_rgba(0,0,0,0.16)]">
        <div class="border-b border-[#e0e0e0] px-5 py-4">
          <h3 id="client-modal-title" class="font-serif text-[28px] leading-none text-black">Notice</h3>
        </div>
        <div class="px-5 py-5">
          <p id="client-modal-message" class="text-[13px] leading-6 text-[#5f5f5f]"></p>
        </div>
        <div class="flex items-center justify-end gap-3 border-t border-[#e0e0e0] px-5 py-4">
          <button id="client-modal-cancel" type="button" class="hidden h-[42px] border border-[#d6d6d6] px-5 text-[11px] font-bold uppercase tracking-[0.18em] text-[#4a4a4a] hover:border-black hover:text-black">Cancel</button>
          <button id="client-modal-ok" type="button" class="h-[42px] border border-black bg-black px-5 text-[11px] font-bold uppercase tracking-[0.18em] text-white hover:bg-zinc-800">OK</button>
        </div>
      </div>
    `;
    document.body.appendChild(root);

    const titleEl = root.querySelector('#client-modal-title');
    const messageEl = root.querySelector('#client-modal-message');
    const okBtn = root.querySelector('#client-modal-ok');
    const cancelBtn = root.querySelector('#client-modal-cancel');

    function openModal(opts) {
      const { title, message, confirmText, cancelText, showCancel } = opts;
      return new Promise((resolve) => {
        titleEl.textContent = title || 'Notice';
        messageEl.textContent = message || '';
        okBtn.textContent = confirmText || 'OK';
        cancelBtn.textContent = cancelText || 'Cancel';
        cancelBtn.classList.toggle('hidden', !showCancel);
        root.classList.remove('hidden');
        root.classList.add('flex');

        function cleanup(result) {
          root.classList.add('hidden');
          root.classList.remove('flex');
          okBtn.removeEventListener('click', onOk);
          cancelBtn.removeEventListener('click', onCancel);
          root.removeEventListener('click', onBackdrop);
          document.removeEventListener('keydown', onEsc);
          resolve(result);
        }

        function onOk() { cleanup(true); }
        function onCancel() { cleanup(false); }
        function onBackdrop(e) { if (e.target === root) cleanup(false); }
        function onEsc(e) { if (e.key === 'Escape') cleanup(false); }

        okBtn.addEventListener('click', onOk);
        cancelBtn.addEventListener('click', onCancel);
        root.addEventListener('click', onBackdrop);
        document.addEventListener('keydown', onEsc);
      });
    }

    window.ClientModal = {
      alert(message, title) {
        return openModal({ title: title || 'Notice', message, showCancel: false, confirmText: 'OK' });
      },
      confirm(message, title) {
        return openModal({ title: title || 'Please Confirm', message, showCancel: true, confirmText: 'Confirm', cancelText: 'Cancel' });
      },
    };

    document.addEventListener('submit', async function (e) {
      const form = e.target;
      if (!(form instanceof HTMLFormElement)) return;
      const text = form.getAttribute('data-confirm');
      if (!text) return;
      e.preventDefault();
      const confirmed = await window.ClientModal.confirm(text, 'Action Confirmation');
      if (confirmed) form.submit();
    });
  })();
</script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    // size selection on product detail
    const sizeButtons = document.querySelectorAll('.size-option');
    sizeButtons.forEach(btn => {
      btn.addEventListener('click', function () {
        sizeButtons.forEach(b => b.classList.remove('border-black', 'bg-black', 'text-white'));
        btn.classList.add('border-black', 'bg-black', 'text-white');
        const hidden = document.getElementById('selected-size');
        if (hidden) hidden.value = btn.dataset.size;
      });
    });
    // pick first size by default
    if (sizeButtons.length > 0) {
      sizeButtons[0].click();
    }

    // handle add to cart form submission if button outside form
    const addCartBtn = document.getElementById('add-to-cart');
    if (addCartBtn) {
      addCartBtn.addEventListener('click', () => {
        const form = document.getElementById('cart-form');
        if (form) form.submit();
      });
    }

    // wishlist placeholder
    const wishBtn = document.getElementById('add-to-wishlist');
    if (wishBtn) {
      wishBtn.addEventListener('click', () => {
        window.ClientModal?.alert('Added to wishlist.', 'Wishlist');
      });
    }

    // product gallery: click sub image to switch main image
    const mainProductImage = document.getElementById('main-product-image');
    const thumbs = document.querySelectorAll('.product-thumb');
    if (mainProductImage && thumbs.length > 0) {
      thumbs.forEach((thumb) => {
        thumb.addEventListener('click', () => {
          const url = thumb.getAttribute('data-image-url');
          if (!url) return;
          mainProductImage.setAttribute('src', url);
          thumbs.forEach((t) => t.classList.remove('ring-2', 'ring-black'));
          thumb.classList.add('ring-2', 'ring-black');
        });
      });
    }

    // simple hero slider
    const slides = document.querySelectorAll('.hero-slide');
    let current = 0;
    function showSlide(idx) {
      slides.forEach((s, i) => {
        const active = i === idx;
        s.classList.toggle('opacity-100', active);
        s.classList.toggle('z-10', active);
        s.classList.toggle('opacity-0', !active);
        s.classList.toggle('pointer-events-none', !active);
        s.classList.toggle('z-0', !active);
      });
    }
    const prevBtn = document.getElementById('slide-prev');
    const nextBtn = document.getElementById('slide-next');
    if (slides.length > 0) {
      showSlide(0);
      if (slides.length > 1) {
        setInterval(() => {
          current = (current + 1) % slides.length;
          showSlide(current);
        }, 5000);
      }
      if (prevBtn) {
        prevBtn.addEventListener('click', () => {
          current = (current - 1 + slides.length) % slides.length;
          showSlide(current);
        });
      }
      if (nextBtn) {
        nextBtn.addEventListener('click', () => {
          current = (current + 1) % slides.length;
          showSlide(current);
        });
      }
    }
  });
</script>
