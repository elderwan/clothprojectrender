<a href="/products/<%= product.id %>" class="group block cursor-pointer">
  <div class="relative overflow-hidden bg-[#f1eee8]">
    <% if (product.category) { %>
      <div class="absolute left-3 top-3 z-10 border border-white/70 bg-white/85 px-2 py-1 text-[10px] uppercase tracking-[0.16em] text-black">
        <%= product.category %>
      </div>
    <% } %>
    <div class="aspect-[4/5] overflow-hidden">
      <% if (product.primary_image) { %>
        <img
          src="<%= product.primary_image %>"
          alt="<%= product.name %>"
          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
        />
      <% } else { %>
        <div class="flex h-full w-full items-center justify-center text-[11px] uppercase tracking-[0.18em] text-black/35">No Image</div>
      <% } %>
    </div>
  </div>
  <div class="space-y-2 pt-4">
    <div class="flex items-start justify-between gap-3">
      <h3 class="max-w-[18ch] text-[14px] leading-6 text-black"><%= product.name %></h3>
      <% if (typeof cardIndex !== 'undefined' && cardIndex !== null) { %>
        <span class="shrink-0 text-[12px] text-black/45"><%= String(cardIndex + 1).padStart(2, '0') %></span>
      <% } %>
    </div>
    <p class="text-[11px] uppercase tracking-[0.16em] text-black/40"><%= product.audience %><% if (product.category) { %> / <%= product.category %><% } %></p>
    <div class="flex items-center justify-between gap-3">
      <p class="text-[14px]">$<%= Number(product.price || 0).toFixed(2) %></p>
      <% if (typeof product.stock_quantity === 'number') { %>
        <p class="text-[12px] text-black/45"><%= product.stock_quantity > 0 ? (product.stock_quantity + ' left') : 'Out of stock' %></p>
      <% } %>
    </div>
  </div>
</a>
