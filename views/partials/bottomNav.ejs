<nav class="fixed bottom-0 left-0 z-50 w-full border-t border-[#e0e0e0] bg-white lg:hidden">
  <%
    const accountTitles = ['My Account', 'Edit Profile', 'Change Password', 'Address Book', 'Order History', 'Order Confirmed'];
    const isAccountActive = accountTitles.includes(title);
    const isWishlistActive = title === 'Wishlist';
    const isHomeActive = title === 'Home' || title === 'MAISON';
    const isShopActive = title === 'Shop' || title === 'Products';
    const isBagActive = title === 'Shopping Bag';
    const isOrderDetailActive = typeof title === 'string' && title.startsWith('Order ');
  %>
  <div class="grid h-[60px] grid-cols-6 items-center">
    <a href="/" class="flex flex-col items-center gap-1">
      <% if (isHomeActive) { %>
        <div class="h-[2px] w-6 bg-black"></div>
      <% } else { %>
        <div class="h-[2px] w-6 bg-transparent"></div>
      <% } %>
      <p class="text-[9px] <%= isHomeActive ? 'font-bold text-black' : 'font-normal text-[#737373]' %>">Home</p>
    </a>
    <a href="/products" class="flex flex-col items-center gap-1">
      <% if (isShopActive) { %>
        <div class="h-[2px] w-6 bg-black"></div>
      <% } else { %>
        <div class="h-[2px] w-6 bg-transparent"></div>
      <% } %>
      <p class="text-[9px] <%= isShopActive ? 'font-bold text-black' : 'font-normal text-[#737373]' %>">Shop</p>
    </a>
    <a href="/products" class="flex flex-col items-center gap-1">
      <div class="h-[2px] w-6 bg-transparent"></div>
      <p class="text-[9px] font-normal text-[#737373]">Search</p>
    </a>
    <a href="/wishlist" class="flex flex-col items-center gap-1">
      <% if (isWishlistActive) { %>
        <div class="h-[2px] w-6 bg-black"></div>
      <% } else { %>
        <div class="h-[2px] w-6 bg-transparent"></div>
      <% } %>
      <p class="text-[9px] <%= isWishlistActive ? 'font-bold text-black' : 'font-normal text-[#737373]' %>">Wishlist</p>
    </a>
    <a href="/profile" class="flex flex-col items-center gap-1">
      <% if (isAccountActive || isOrderDetailActive) { %>
        <div class="h-[2px] w-6 bg-black"></div>
      <% } else { %>
        <div class="h-[2px] w-6 bg-transparent"></div>
      <% } %>
      <p class="text-[9px] <%= isAccountActive || isOrderDetailActive ? 'font-bold text-black' : 'font-normal text-[#737373]' %>">Account</p>
    </a>
    <a href="/cart" class="flex flex-col items-center gap-1">
      <% if (isBagActive) { %>
        <div class="h-[2px] w-6 bg-black"></div>
      <% } else { %>
        <div class="h-[2px] w-6 bg-transparent"></div>
      <% } %>
      <p class="text-[9px] <%= isBagActive ? 'font-bold text-black' : 'font-normal text-[#737373]' %>">Bag</p>
    </a>
  </div>
</nav>
