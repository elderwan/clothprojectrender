<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | MAISON</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }
    h1, .font-serif { font-family: 'Georgia', serif; }
  </style>
</head>
<body class="bg-white text-black pb-[60px] lg:pb-0">
  <!-- Header -->
  <%- include('../partials/header', { user, cartCount }) %>  

  <!-- Main Content -->
  <main class="mx-auto max-w-[1440px] px-5 py-8 lg:px-[140px] lg:py-[60px]">
    <div class="flex items-center gap-4 mb-6">
      <a href="/profile" class="text-[11px] font-bold uppercase hover:underline">← Back to Profile</a>
    </div>

    <h1 class="text-[24px] lg:text-[36px] font-normal mb-8 uppercase font-serif">Change Password</h1>
    <div class="h-px w-full bg-[#e0e0e0] mb-8 lg:mb-10"></div>

    <div class="max-w-[500px]">
      <% if (error) { %>
        <div class="mb-6 p-4 bg-red-50 text-red-600 text-[12px] border border-red-100">
          <%= error %>
        </div>
      <% } %>
      <% if (success) { %>
        <div class="mb-6 p-4 bg-green-50 text-green-600 text-[12px] border border-green-100">
          <%= success %>
        </div>
      <% } %>

      <form action="/profile/change-password" method="POST" class="space-y-6">
        <div>
          <label for="current_password" class="block text-[10px] font-bold uppercase text-[#737373] mb-2 tracking-widest">Current Password</label>
          <input type="password" id="current_password" name="current_password" required
                 class="w-full h-[44px] border border-[#e0e0e0] px-4 text-[13px] focus:outline-none focus:border-black transition-colors duration-200" />
        </div>
        <div>
          <label for="new_password" class="block text-[10px] font-bold uppercase text-[#737373] mb-2 tracking-widest">New Password</label>
          <input type="password" id="new_password" name="new_password" required
                 class="w-full h-[44px] border border-[#e0e0e0] px-4 text-[13px] focus:outline-none focus:border-black transition-colors duration-200" />
        </div>
        <div>
          <label for="confirm_password" class="block text-[10px] font-bold uppercase text-[#737373] mb-2 tracking-widest">Confirm New Password</label>
          <input type="password" id="confirm_password" name="confirm_password" required
                 class="w-full h-[44px] border border-[#e0e0e0] px-4 text-[13px] focus:outline-none focus:border-black transition-colors duration-200" />
        </div>

        <div class="pt-4">
          <button type="submit" class="w-full h-[52px] bg-black text-white text-[11px] font-bold uppercase tracking-widest hover:bg-zinc-800 transition-colors duration-200">
            Update Password
          </button>
        </div>
      </form>
    </div>
  </main>

  <!-- Footer -->
  <footer class="border-t border-[#e0e0e0] bg-white mt-16 pb-[60px] lg:pb-0">
    <div class="mx-auto max-w-[1440px] px-5 py-12 lg:px-[140px]">
      <div class="flex flex-col lg:flex-row justify-between gap-12">
        <div class="lg:w-1/3">
          <p class="font-serif text-[16px] font-normal mb-4">MAISON</p>
          <p class="text-[11px] text-[#737373]">Luxury since 2026</p>
        </div>
        <div class="lg:w-1/3 text-left lg:text-right ml-auto">
          <p class="text-[11px] font-bold mb-4 uppercase">Account</p>
          <div class="flex gap-4 lg:justify-end">
            <a href="/profile" class="text-[11px] text-[#737373] hover:text-black">My Account</a>
            <a href="/orders" class="text-[11px] text-[#737373] hover:text-black">Order History</a>
          </div>
        </div>
      </div>
      <div class="mt-16 pt-8 border-t border-[#e0e0e0]">
        <p class="text-[10px] text-[#737373]">© 2026 MAISON. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <!-- Bottom Nav -->
  <%- include('../partials/bottomNav', { title }) %>
</body>
</html>
