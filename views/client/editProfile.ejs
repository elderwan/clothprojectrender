<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | MAISON</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }
    h1, .font-serif { font-family: 'Georgia', serif; }
  </style>
</head>
<body class="bg-white text-black pb-[60px] lg:pb-0">
  <%- include('../partials/header', { user, cartCount }) %>

  <main class="mx-auto max-w-[1440px] px-5 py-8 lg:px-[140px] lg:py-[60px]">
    <div class="flex items-center gap-4 mb-6">
      <a href="/profile" class="text-[11px] font-bold uppercase tracking-[0.14em] hover:underline">← Back to Profile</a>
    </div>

    <div class="max-w-[980px]">
      <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-[#737373]">Profile Settings</p>
      <h1 class="mt-4 text-[32px] font-normal uppercase font-serif lg:text-[44px]">Edit Personal Information</h1>
      <p class="mt-4 max-w-[560px] text-[13px] leading-6 text-[#6b6b6b]">
        Update your core account details here. Delivery addresses are managed separately from your profile for a cleaner account workflow.
      </p>
    </div>

    <div class="mt-10 h-px w-full bg-[#e0e0e0]"></div>

    <% if (error) { %>
      <div class="mt-8 max-w-[820px] border border-red-100 bg-red-50 p-4 text-[12px] text-red-600">
        <%= error %>
      </div>
    <% } %>
    <% if (success) { %>
      <div class="mt-8 max-w-[820px] border border-green-100 bg-green-50 p-4 text-[12px] text-green-600">
        <%= success %>
      </div>
    <% } %>

    <section class="mt-10 grid grid-cols-1 gap-8 lg:grid-cols-[minmax(0,0.74fr)_minmax(320px,0.26fr)] lg:items-start">
      <div class="border border-[#e0e0e0] bg-white">
        <div class="border-b border-[#e0e0e0] px-6 py-5">
          <p class="text-[10px] font-bold uppercase tracking-[0.18em]">Personal Information</p>
          <p class="mt-2 text-[12px] text-[#737373]">Keep your account details up to date for orders and communication.</p>
        </div>

        <form action="/profile/edit" method="POST" class="space-y-6 px-6 py-6 lg:px-8 lg:py-8">
          <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
            <div class="sm:col-span-2">
              <label for="full_name" class="mb-2 block text-[10px] font-bold uppercase tracking-[0.18em] text-[#737373]">Full Name</label>
              <input
                type="text"
                id="full_name"
                name="full_name"
                value="<%= user.full_name %>"
                required
                class="h-[48px] w-full border border-[#e0e0e0] px-4 text-[13px] transition-colors duration-200 focus:border-black focus:outline-none"
              />
            </div>

            <div class="sm:col-span-2">
              <label for="email" class="mb-2 block text-[10px] font-bold uppercase tracking-[0.18em] text-[#737373]">Email Address</label>
              <input
                type="email"
                id="email"
                value="<%= user.email %>"
                disabled
                class="h-[48px] w-full cursor-not-allowed border border-[#e0e0e0] bg-[#f5f5f5] px-4 text-[13px] text-[#737373]"
              />
            </div>

            <div class="sm:col-span-2">
              <label for="phone" class="mb-2 block text-[10px] font-bold uppercase tracking-[0.18em] text-[#737373]">Phone Number</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                value="<%= user.phone || '' %>"
                class="h-[48px] w-full border border-[#e0e0e0] px-4 text-[13px] transition-colors duration-200 focus:border-black focus:outline-none"
              />
            </div>
          </div>

          <div class="flex flex-col gap-3 border-t border-[#e0e0e0] pt-6 sm:flex-row">
            <button type="submit" class="inline-flex h-[48px] items-center justify-center border border-black bg-black px-8 text-[11px] font-bold uppercase tracking-[0.18em] text-white transition-colors duration-200 hover:bg-zinc-800">
              Save Changes
            </button>
            <a href="/profile/addresses" class="inline-flex h-[48px] items-center justify-center border border-black px-8 text-[11px] font-bold uppercase tracking-[0.18em] transition-colors duration-200 hover:bg-black hover:text-white">
              Manage Addresses
            </a>
          </div>
        </form>
      </div>

      <aside class="border border-[#e0e0e0] bg-[#fafafa]">
        <div class="border-b border-[#e0e0e0] px-6 py-5">
          <p class="text-[10px] font-bold uppercase tracking-[0.18em]">Account Notes</p>
        </div>
        <div class="space-y-5 px-6 py-6">
          <div>
            <p class="text-[11px] font-bold uppercase tracking-[0.16em]">Member Since</p>
            <p class="mt-2 text-[13px] text-[#737373]"><%= new Date(user.created_at).toLocaleDateString('en-US', { month: 'long', year: 'numeric' }) %></p>
          </div>
          <div>
            <p class="text-[11px] font-bold uppercase tracking-[0.16em]">Primary Email</p>
            <p class="mt-2 break-all text-[13px] text-[#737373]"><%= user.email %></p>
          </div>
          <div class="border-t border-[#e0e0e0] pt-5">
            <p class="text-[12px] leading-6 text-[#737373]">
              Need to update shipping details or default delivery preferences? Use the dedicated address book page from your account center.
            </p>
          </div>
        </div>
      </aside>
    </section>
  </main>

  <footer class="border-t border-[#e0e0e0] bg-white mt-16 pb-[60px] lg:pb-0">
    <div class="mx-auto max-w-[1440px] px-5 py-12 lg:px-[140px]">
      <div class="flex flex-col lg:flex-row justify-between gap-12">
        <div class="lg:w-1/3">
          <p class="font-serif text-[16px] font-normal mb-4">MAISON</p>
          <p class="text-[11px] text-[#737373]">Luxury since 2026</p>
        </div>
        <div class="lg:w-1/3 text-left lg:text-right ml-auto">
          <p class="text-[11px] font-bold mb-4 uppercase">Account</p>
          <div class="flex gap-4 lg:justify-end">
            <a href="/profile" class="text-[11px] text-[#737373] hover:text-black">My Account</a>
            <a href="/orders" class="text-[11px] text-[#737373] hover:text-black">Order History</a>
          </div>
        </div>
      </div>
      <div class="mt-16 pt-8 border-t border-[#e0e0e0]">
        <p class="text-[10px] text-[#737373]">© 2026 MAISON. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <%- include('../partials/bottomNav', { title }) %>
</body>
</html>
