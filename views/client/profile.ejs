<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | MAISON</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-white text-black">
  <!-- Header -->
  <%- include('../partials/header', { user, cartCount }) %>  

  <!-- Main Content -->
  <main class="mx-auto max-w-[1440px] px-4 py-8 lg:px-[140px]">
    <h1 class="font-serif text-[36px] font-normal mb-4">MY ACCOUNT</h1>
    <div class="h-px w-full bg-[#e0e0e0] mb-8"></div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Account Info -->
      <div class="lg:col-span-2 space-y-8">
        <div>
          <p class="text-[11px] font-bold mb-4">ACCOUNT INFORMATION</p>
          <div class="h-px w-full bg-[#e0e0e0] mb-4"></div>

          <div class="space-y-4">
            <div>
              <label class="block text-[11px] font-bold mb-2">FULL NAME</label>
              <input type="text" value="<%= user ? user.full_name : '' %>" class="w-full border border-[#e0e0e0] px-3 py-2 text-[12px]" readonly />
            </div>
            <div>
              <label class="block text-[11px] font-bold mb-2">EMAIL ADDRESS</label>
              <input type="email" value="<%= user ? user.email : '' %>" class="w-full border border-[#e0e0e0] px-3 py-2 text-[12px]" readonly />
            </div>
            <div>
              <label class="block text-[11px] font-bold mb-2">PHONE NUMBER</label>
              <input type="tel" value="<%= user ? user.phone || '' : '' %>" class="w-full border border-[#e0e0e0] px-3 py-2 text-[12px]" readonly />
            </div>
          </div>

          <button class="mt-6 border border-black px-6 py-3 text-[11px] font-bold text-black hover:bg-black hover:text-white">
            EDIT INFORMATION
          </button>
        </div>

        <!-- Address Book -->
        <div>
          <p class="text-[11px] font-bold mb-4">ADDRESS BOOK</p>
          <div class="h-px w-full bg-[#e0e0e0] mb-4"></div>

          <% if (addresses && addresses.length > 0) { %>
            <div class="space-y-4">
              <% addresses.forEach(address => { %>
                <div class="border border-[#e0e0e0] p-4">
                  <p class="text-[12px] font-bold mb-2"><%= address.full_name %></p>
                  <p class="text-[12px] text-[#737373] mb-1"><%= address.street_address %></p>
                  <p class="text-[12px] text-[#737373] mb-1"><%= address.city %>, <%= address.state %> <%= address.zip_code %></p>
                  <p class="text-[12px] text-[#737373]"><%= address.country %></p>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <p class="text-[12px] text-[#737373]">No addresses saved yet.</p>
          <% } %>

          <button class="mt-4 border border-black px-6 py-3 text-[11px] font-bold text-black hover:bg-black hover:text-white">
            ADD NEW ADDRESS
          </button>
        </div>
      </div>

      <!-- Order History -->
      <div class="space-y-6">
        <div>
          <p class="text-[11px] font-bold mb-4">ORDER HISTORY</p>
          <div class="h-px w-full bg-[#e0e0e0] mb-4"></div>

          <% if (orders && orders.length > 0) { %>
            <div class="space-y-4">
              <% orders.slice(0, 3).forEach(order => { %>
                <div class="border border-[#e0e0e0] p-4">
                  <div class="flex justify-between items-start mb-2">
                    <p class="text-[12px] font-bold">Order #<%= order.id %></p>
                    <p class="text-[10px] text-[#737373]"><%= new Date(order.created_at).toLocaleDateString() %></p>
                  </div>
                  <p class="text-[12px] text-[#737373] mb-2"><%= order.status %></p>
                  <p class="text-[12px] font-bold">$<%= Number(order.total).toFixed(2) %></p>
                  <a href="/orders/<%= order.id %>" class="text-[11px] text-black hover:underline mt-2 inline-block">View Details</a>
                </div>
              <% }) %>
            </div>
          <% } else { %>
            <p class="text-[12px] text-[#737373]">No orders yet.</p>
          <% } %>

          <a href="/orders" class="inline-block mt-4 border border-black px-6 py-3 text-[11px] font-bold text-black hover:bg-black hover:text-white">
            VIEW ALL ORDERS
          </a>
        </div>
      </div>
    </div>
  </main>

  <!-- Footer -->
  <footer class="border-t border-[#e0e0e0] bg-white mt-16">
    <div class="mx-auto max-w-[1440px] px-4 py-8 lg:px-[140px]">
      <div class="grid gap-8 md:grid-cols-3">
        <div>
          <p class="font-serif text-[16px] font-normal">MAISON</p>
          <p class="mt-2 text-[11px] text-[#737373]">Luxury since 2026</p>
        </div>
        <div>
          <p class="text-[11px] font-bold">EXPLORE</p>
          <div class="mt-2 space-y-1 text-[11px] text-[#737373]">
            <a href="/products?category=women" class="block hover:text-black">Women</a>
            <a href="/products?category=men" class="block hover:text-black">Men</a>
            <a href="/products?category=kids" class="block hover:text-black">Kids</a>
          </div>
        </div>
        <div>
          <p class="text-[11px] font-bold">ACCOUNT</p>
          <div class="mt-2 space-y-1 text-[11px] text-[#737373]">
            <% if (user) { %>
              <a href="/profile" class="block hover:text-black">My Account</a>
              <a href="/orders" class="block hover:text-black">Orders</a>
              <a href="/logout" class="block hover:text-black">Sign Out</a>
            <% } else { %>
              <a href="/login" class="block hover:text-black">Sign In</a>
              <a href="/register" class="block hover:text-black">Register</a>
            <% } %>
          </div>
        </div>
      </div>
      <div class="mt-8 border-t border-[#e0e0e0] pt-6">
        <p class="text-[10px] text-[#737373]">© 2026 MAISON. All rights reserved.</p>
      </div>
    </div>
  </footer>
</body>
</html>

