<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | MAISON</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-white text-black">
  <!-- Header -->
  <%- include('../partials/header', { user, cartCount }) %>  

  <!-- Breadcrumb -->
  <div class="border-b border-[#e0e0e0] bg-white">
    <div class="mx-auto max-w-[1440px] px-4 py-4 lg:px-[140px]">
      <p class="text-[11px] text-[#737373]">Home / <%= audience ? audience.charAt(0).toUpperCase() + audience.slice(1) : 'All' %><%= categoryName ? (' / ' + categoryName) : '' %></p>
    </div>
  </div>

  <!-- Main Content -->
  <main class="mx-auto max-w-[1440px] px-4 py-8 lg:px-[140px]">
    <h1 class="font-serif text-[36px] font-normal mb-6"><%= audience ? audience.toUpperCase() : 'ALL' %></h1>

    <!-- Filters -->
    <div class="mb-6">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div class="flex items-center gap-4 text-[11px] font-bold">
          <a href="/products?<%= categoryName ? ('category_name=' + encodeURIComponent(categoryName) + '&') : '' %><%= q ? ('q=' + encodeURIComponent(q) + '&') : '' %>sort=<%= sort || 'time_desc' %>"
             class="<%= !audience ? 'text-black underline underline-offset-4' : 'text-[#737373]' %> hover:text-black">ALL</a>
          <a href="/products?audience=men<%= categoryName ? ('&category_name=' + encodeURIComponent(categoryName)) : '' %><%= q ? ('&q=' + encodeURIComponent(q)) : '' %>&sort=<%= sort || 'time_desc' %>"
             class="<%= audience === 'men' ? 'text-black underline underline-offset-4' : 'text-[#737373]' %> hover:text-black">MEN</a>
          <a href="/products?audience=women<%= categoryName ? ('&category_name=' + encodeURIComponent(categoryName)) : '' %><%= q ? ('&q=' + encodeURIComponent(q)) : '' %>&sort=<%= sort || 'time_desc' %>"
             class="<%= audience === 'women' ? 'text-black underline underline-offset-4' : 'text-[#737373]' %> hover:text-black">WOMEN</a>
          <a href="/products?audience=kids<%= categoryName ? ('&category_name=' + encodeURIComponent(categoryName)) : '' %><%= q ? ('&q=' + encodeURIComponent(q)) : '' %>&sort=<%= sort || 'time_desc' %>"
             class="<%= audience === 'kids' ? 'text-black underline underline-offset-4' : 'text-[#737373]' %> hover:text-black">KIDS</a>
        </div>
        <form method="GET" action="/products" class="flex items-center gap-2">
          <% if (audience) { %><input type="hidden" name="audience" value="<%= audience %>" /><% } %>
          <% if (categoryName) { %><input type="hidden" name="category_name" value="<%= categoryName %>" /><% } %>
          <% if (sort) { %><input type="hidden" name="sort" value="<%= sort %>" /><% } %>
          <input type="text" name="q" value="<%= q || '' %>" placeholder="Search products..."
                 class="h-[32px] w-[220px] border border-[#e0e0e0] px-2 text-[11px]" />
          <button type="submit" class="h-[32px] border border-black bg-black px-3 text-[11px] font-bold text-white">Search</button>
        </form>
      </div>

      <div class="mt-4 flex flex-wrap items-center gap-4">
        <div class="flex items-center gap-2">
          <a href="/products?<%= audience ? ('audience=' + audience + '&') : '' %><%= q ? ('q=' + encodeURIComponent(q) + '&') : '' %>sort=<%= sort || 'time_desc' %>"
             class="inline-flex h-[32px] items-center justify-center border px-3 text-[11px] font-bold <%= !categoryName ? 'border-black bg-black text-white' : 'border-[#e0e0e0] text-black' %>">All</a>
          <% (categoryNames || []).forEach((name) => { %>
            <a href="/products?<%= audience ? ('audience=' + audience + '&') : '' %>category_name=<%= encodeURIComponent(name) %><%= q ? ('&q=' + encodeURIComponent(q)) : '' %>&sort=<%= sort || 'time_desc' %>"
               class="inline-flex h-[32px] items-center justify-center border px-3 text-[11px] <%= categoryName === name ? 'border-black bg-black font-bold text-white' : 'border-transparent text-black hover:underline' %>"><%= name %></a>
          <% }) %>
        </div>
        <div class="ml-auto">
          <form method="GET" action="/products" class="flex items-center gap-2">
            <% if (audience) { %><input type="hidden" name="audience" value="<%= audience %>" /><% } %>
            <% if (categoryName) { %><input type="hidden" name="category_name" value="<%= categoryName %>" /><% } %>
            <% if (q) { %><input type="hidden" name="q" value="<%= q %>" /><% } %>
            <label class="text-[11px] text-[#737373]" for="sort-select">Sorted:</label>
            <select id="sort-select" name="sort" class="h-[32px] border border-[#e0e0e0] px-2 text-[11px]" onchange="this.form.submit()">
              <option value="time_desc" <%= (sort || 'time_desc') === 'time_desc' ? 'selected' : '' %>>New Arrivals</option>
              <option value="sales_desc" <%= sort === 'sales_desc' ? 'selected' : '' %>>Best Sellers</option>
              <option value="price_asc" <%= sort === 'price_asc' ? 'selected' : '' %>>Price (low to high)</option>
              <option value="price_desc" <%= sort === 'price_desc' ? 'selected' : '' %>>Price (high to low)</option>
              <option value="time_asc" <%= sort === 'time_asc' ? 'selected' : '' %>>Time (old to new)</option>
            </select>
          </form>
        </div>
      </div>
      <div class="mt-4 h-px w-full bg-[#e0e0e0]"></div>
    </div>

    <!-- Products Grid -->
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4">
      <% if (products && products.length > 0) { %>
        <% products.forEach(product => { %>
          <a href="/products/<%= product.id %>" class="group cursor-pointer">
            <div class="aspect-square bg-[#f5f5f5] mb-4 overflow-hidden">
              <% if (product.primary_image) { %>
                <img src="<%= product.primary_image %>" alt="<%= product.name %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
              <% } %>
            </div>
            <p class="text-[13px] font-normal mb-1"><%= product.name %></p>
            <p class="text-[13px] text-[#737373]">$<%= Number(product.price || 0).toFixed(2) %></p>
          </a>
        <% }) %>
      <% } else { %>
        <div class="col-span-full text-center py-16">
          <p class="text-[13px] text-[#737373]">No products found.</p>
        </div>
      <% } %>
    </div>

    <!-- Pagination -->
    <% if (pagination && pagination.totalPages > 1) { %>
      <%
        const currentPage = pagination.page || 1;
        const totalPages = pagination.totalPages || 1;
        const startPage = Math.max(1, currentPage - 2);
        const endPage = Math.min(totalPages, currentPage + 2);
        const qp = new URLSearchParams();
        if (audience) qp.set('audience', audience);
        if (categoryName) qp.set('category_name', categoryName);
        if (q) qp.set('q', q);
        if (sort) qp.set('sort', sort);
        const makeLink = (targetPage) => {
          const next = new URLSearchParams(qp.toString());
          if (targetPage > 1) next.set('page', String(targetPage));
          return '/products' + (next.toString() ? ('?' + next.toString()) : '');
        };
      %>
      <div class="mt-12 flex flex-col items-center gap-3">
        <p class="text-[11px] text-[#737373]">Page <%= currentPage %> / <%= totalPages %></p>
        <div class="flex items-center gap-2">
          <% if (pagination.hasPrev) { %>
            <a href="<%= makeLink(currentPage - 1) %>" class="inline-flex h-[36px] min-w-[52px] items-center justify-center border border-[#e0e0e0] px-3 text-[12px] hover:bg-[#f5f5f5]">Prev</a>
          <% } %>
          <% for (let p = startPage; p <= endPage; p++) { %>
            <a href="<%= makeLink(p) %>" class="inline-flex h-[36px] w-[36px] items-center justify-center border text-[13px] <%= p === currentPage ? 'border-black bg-black text-white' : 'border-[#e0e0e0] text-black hover:bg-[#f5f5f5]' %>"><%= p %></a>
          <% } %>
          <% if (pagination.hasNext) { %>
            <a href="<%= makeLink(currentPage + 1) %>" class="inline-flex h-[36px] min-w-[52px] items-center justify-center border border-[#e0e0e0] px-3 text-[12px] hover:bg-[#f5f5f5]">Next</a>
          <% } %>
        </div>
      </div>
    <% } %>
  </main>

  <!-- Footer -->
  <footer class="border-t border-[#e0e0e0] bg-white mt-16">
    <div class="mx-auto max-w-[1440px] px-4 py-8 lg:px-[140px]">
      <div class="grid gap-8 md:grid-cols-3">
        <div>
          <p class="font-serif text-[16px] font-normal">MAISON</p>
          <p class="mt-2 text-[11px] text-[#737373]">Luxury since 2026</p>
        </div>
        <div>
          <p class="text-[11px] font-bold">EXPLORE</p>
          <div class="mt-2 space-y-1 text-[11px] text-[#737373]">
            <a href="/products?category=women" class="block hover:text-black">Women</a>
            <a href="/products?category=men" class="block hover:text-black">Men</a>
            <a href="/products?category=kids" class="block hover:text-black">Kids</a>
          </div>
        </div>
        <div>
          <p class="text-[11px] font-bold">ACCOUNT</p>
          <div class="mt-2 space-y-1 text-[11px] text-[#737373]">
            <% if (user) { %>
              <a href="/profile" class="block hover:text-black">My Account</a>
              <a href="/orders" class="block hover:text-black">Orders</a>
              <a href="/logout" class="block hover:text-black">Sign Out</a>
            <% } else { %>
              <a href="/login" class="block hover:text-black">Sign In</a>
              <a href="/register" class="block hover:text-black">Register</a>
            <% } %>
          </div>
        </div>
      </div>
      <div class="mt-8 border-t border-[#e0e0e0] pt-6">
        <p class="text-[10px] text-[#737373]">© 2026 MAISON. All rights reserved.</p>
      </div>
    </div>
  </footer>
  <%- include('../partials/clientScripts') %>
</body>
</html>

