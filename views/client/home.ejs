<!doctype html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>
    <%= title %> | MAISON
  </title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-white text-black">
  <!-- Header -->
  <%- include('../partials/header', { user, cartCount }) %>

    <!-- Home Banner -->
    <section class="border-b border-[#e6e0d8] bg-[#fcfcfa]">
      <% if (homeBanners && homeBanners.length > 0) { %>
        <% homeBanners.forEach((b, idx) => { %>
          <% const collectionLabel = (b.product_category_name || 'Collection').toUpperCase(); %>
          <% const collectionHref = (b.product_audience && b.product_category_name)
            ? ('/products?audience=' + encodeURIComponent(b.product_audience) + '&category_name=' + encodeURIComponent(b.product_category_name))
            : (b.product_audience ? ('/products?audience=' + encodeURIComponent(b.product_audience)) : '/products'); %>
          <% const textOnLeft = idx % 2 === 1; %>
          <div class="<%= idx > 0 ? 'border-t border-[#e6e0d8]' : '' %>">
            <div class="mx-auto grid max-w-[1440px] gap-9 px-4 py-10 lg:min-h-[860px] lg:px-[140px] lg:py-16 <%= textOnLeft ? 'lg:grid-cols-[0.38fr_0.62fr]' : 'lg:grid-cols-[0.62fr_0.38fr]' %>">
              <div class="<%= textOnLeft ? 'lg:order-2' : '' %> bg-[#efebe5] self-end">
                <div class="aspect-[4/5] w-full overflow-hidden">
                  <img src="<%= b.image_url %>" alt="<%= b.title %>" class="h-full w-full object-cover object-center" />
                </div>
              </div>
              <div class="<%= textOnLeft ? 'lg:order-1 lg:items-end lg:text-right lg:pl-0 lg:pr-6' : 'lg:items-start lg:text-left lg:pl-6 lg:pr-0' %> flex flex-col self-end pb-1">
                <div class="<%= textOnLeft ? 'items-end text-right' : 'items-start text-left' %> flex w-full max-w-[360px] flex-col">
                  <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-black/45"><%= collectionLabel %></p>
                  <h1 class="mt-5 max-w-[8ch] font-serif text-[46px] leading-[0.92] lg:text-[88px]"><%= b.title %></h1>
                  <% if (b.description) { %>
                    <p class="mt-6 max-w-[42ch] whitespace-pre-line text-[14px] leading-8 text-black/62"><%= b.description %></p>
                  <% } %>
                  <div class="<%= textOnLeft ? 'justify-end' : 'justify-start' %> mt-10 flex w-full flex-wrap gap-3">
                    <a href="<%= b.product_id ? ('/products/' + b.product_id) : '/products' %>" class="inline-flex h-11 items-center border border-black bg-black px-5 text-[11px] font-semibold uppercase tracking-[0.18em] text-white transition-colors duration-200 hover:bg-transparent hover:text-black">Shop Now</a>
                    <a href="<%= collectionHref %>" class="inline-flex h-11 items-center border border-black/20 px-5 text-[11px] font-semibold uppercase tracking-[0.18em] text-black transition-colors duration-200 hover:border-black">Explore Collection</a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div class="mx-auto grid max-w-[1440px] gap-9 px-4 py-10 lg:min-h-[860px] lg:grid-cols-[0.62fr_0.38fr] lg:px-[140px] lg:py-16">
          <div class="bg-[#efebe5] self-end">
            <div class="aspect-[4/5] w-full bg-[#e7e0d6]"></div>
          </div>
          <div class="flex flex-col items-start self-end pb-1 lg:pl-6">
            <div class="flex w-full max-w-[360px] flex-col items-start text-left">
              <p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-black/45">Spring Selection</p>
              <h1 class="mt-5 max-w-[8ch] font-serif text-[46px] leading-[0.92] lg:text-[88px]">The new classics of MAISON.</h1>
              <p class="mt-6 max-w-[42ch] text-[14px] leading-8 text-black/62">Discover refined silhouettes, quieter palettes, and cleaner seasonal essentials.</p>
              <div class="mt-10 flex w-full flex-wrap justify-start gap-3">
                <a href="/products" class="inline-flex h-11 items-center border border-black bg-black px-5 text-[11px] font-semibold uppercase tracking-[0.18em] text-white transition-colors duration-200 hover:bg-transparent hover:text-black">Shop Now</a>
              </div>
            </div>
          </div>
        </div>
      <% } %>
    </section>

    <!-- New Arrivals Section -->
    <section class="py-16">
      <div class="mx-auto max-w-[1440px] px-4 lg:px-[140px]">
        <div class="mb-8">
          <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-[#737373]">NEW ARRIVALS</p>
          <div class="mt-2 h-px w-full bg-[#e0e0e0]"></div>
        </div>

        <div class="grid grid-cols-1 gap-x-8 gap-y-12 md:grid-cols-2 lg:grid-cols-4">
          <% if (newArrivals && newArrivals.length> 0) { %>
            <% newArrivals.forEach((product, idx)=> { %>
              <%- include('../partials/productCard', { product, cardIndex: idx }) %>
              <% }) %>
                <% } else { %>
                  <p class="text-[13px] text-[#737373]">No items to show.</p>
                  <% } %>
        </div>
      </div>
    </section>

    <section class="pb-16">
      <div class="mx-auto max-w-[1440px] px-4 lg:px-[140px]">
        <div class="mb-8">
          <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-[#737373]">MAN TRENDS</p>
          <div class="mt-2 h-px w-full bg-[#e0e0e0]"></div>
        </div>
        <div class="grid grid-cols-1 gap-x-8 gap-y-12 md:grid-cols-2 lg:grid-cols-4">
          <% if (manTrends && manTrends.length> 0) { %>
            <% manTrends.forEach((product, idx)=> { %>
              <%- include('../partials/productCard', { product, cardIndex: idx }) %>
              <% }) %>
                <% } else { %>
                  <p class="text-[13px] text-[#737373]">No items to show.</p>
                  <% } %>
        </div>
      </div>
    </section>

    <section class="pb-16">
      <div class="mx-auto max-w-[1440px] px-4 lg:px-[140px]">
        <div class="mb-8">
          <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-[#737373]">WOMAN TRENDS</p>
          <div class="mt-2 h-px w-full bg-[#e0e0e0]"></div>
        </div>
        <div class="grid grid-cols-1 gap-x-8 gap-y-12 md:grid-cols-2 lg:grid-cols-4">
          <% if (womanTrends && womanTrends.length> 0) { %>
            <% womanTrends.forEach((product, idx)=> { %>
              <%- include('../partials/productCard', { product, cardIndex: idx }) %>
              <% }) %>
                <% } else { %>
                  <p class="text-[13px] text-[#737373]">No items to show.</p>
                  <% } %>
        </div>
      </div>
    </section>

    <section class="pb-16">
      <div class="mx-auto max-w-[1440px] px-4 lg:px-[140px]">
        <div class="mb-8">
          <p class="text-[11px] font-bold uppercase tracking-[0.18em] text-[#737373]">KID TRENDS</p>
          <div class="mt-2 h-px w-full bg-[#e0e0e0]"></div>
        </div>
        <div class="grid grid-cols-1 gap-x-8 gap-y-12 md:grid-cols-2 lg:grid-cols-4">
          <% if (kidTrends && kidTrends.length> 0) { %>
            <% kidTrends.forEach((product, idx)=> { %>
              <%- include('../partials/productCard', { product, cardIndex: idx }) %>
              <% }) %>
                <% } else { %>
                  <p class="text-[13px] text-[#737373]">No items to show.</p>
                  <% } %>
        </div>
      </div>
    </section>

    <!-- The Edit Section -->
    <section class="bg-[#f5f5f5] py-16">
      <div class="mx-auto max-w-[1440px] px-4 lg:px-[140px]">
        <div class="mb-8">
          <p class="text-[11px] font-bold text-[#737373]">THE EDIT</p>
          <div class="mt-2 h-px w-[1160px] bg-[#e0e0e0]"></div>
        </div>

        <!-- <div class="grid grid-cols-1 gap-8 lg:grid-cols-2">
          <div class="aspect-[560/320] bg-[#f5f5f5] border border-[#e0e0e0]">
            <p class="absolute bottom-4 left-1/2 -translate-x-1/2 text-[10px] text-[#737373]">Editorial 1</p>
          </div>

          <div class="space-y-8">
            <div class="aspect-[440/148] bg-[#f5f5f5] border border-[#e0e0e0]">
              <p class="absolute bottom-4 left-1/2 -translate-x-1/2 text-[10px] text-[#737373]">Editorial 2</p>
            </div>
            <div class="aspect-[440/148] bg-[#f5f5f5] border border-[#e0e0e0]">
              <p class="absolute bottom-4 left-1/2 -translate-x-1/2 text-[10px] text-[#737373]">Editorial 3</p>
            </div>
          </div>
        </div> -->

        <div class="mt-16 text-center">
          <h2 class="font-serif text-[24px] font-normal">The New Classics</h2>
          <p class="mt-4 text-[13px] text-[#737373]">Elevated everyday essentials for the modern wardrobe.</p>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="border-t border-[#e0e0e0] bg-white">
      <div class="mx-auto max-w-[1440px] px-4 py-8 lg:px-[140px]">
        <div class="grid gap-8 md:grid-cols-3">
          <div>
            <p class="font-serif text-[16px] font-normal">MAISON</p>
            <p class="mt-2 text-[11px] text-[#737373]">Luxury since 2026</p>
          </div>
          <div>
            <p class="text-[11px] font-bold">EXPLORE</p>
            <div class="mt-2 space-y-1 text-[11px] text-[#737373]">
              <a href="/products?category=women" class="block hover:text-black">Women</a>
              <a href="/products?category=men" class="block hover:text-black">Men</a>
              <a href="/products?category=kids" class="block hover:text-black">Kids</a>
            </div>
          </div>
          <div>
            <p class="text-[11px] font-bold">ACCOUNT</p>
            <div class="mt-2 space-y-1 text-[11px] text-[#737373]">
              <% if (user) { %>
                <a href="/profile" class="block hover:text-black">My Account</a>
                <a href="/orders" class="block hover:text-black">Orders</a>
                <a href="/logout" class="block hover:text-black">Sign Out</a>
                <% } else { %>
                  <a href="/login" class="block hover:text-black">Sign In</a>
                  <a href="/register" class="block hover:text-black">Register</a>
                  <% } %>
            </div>
          </div>
        </div>
        <div class="mt-8 border-t border-[#e0e0e0] pt-6">
          <p class="text-[10px] text-[#737373]">© 2026 MAISON. All rights reserved.</p>
        </div>
      </div>
    </footer>
    <%- include('../partials/clientScripts') %>
</body>

</html>
