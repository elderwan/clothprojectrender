<!doctype html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>
    <%= title %> | MAISON
  </title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-white text-black">
  <!-- Header -->
  <%- include('../partials/header', { user, cartCount }) %>


    <!-- Hero Banner -->
    <section class="relative h-[380px] overflow-hidden md:h-[580px] bg-zinc-200">
      <% if (banners && banners.length> 0) { %>
        <% banners.forEach((b, idx)=> { %>
          <div
            class="hero-slide absolute inset-0 transition-opacity duration-700 ease-in-out <%= idx === 0 ? 'opacity-100 z-10' : 'opacity-0 pointer-events-none z-0' %>">
            <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('<%= b.image_url %>');"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
            <div class="relative h-full">
              <div class="absolute bottom-8 left-0 w-full px-4 lg:bottom-12 lg:px-[140px]">
                <div class="max-w-[700px] text-white">
                  <h1 class="font-serif text-[30px] leading-tight md:text-[56px]">
                    <%= b.title %>
                  </h1>
                  <% if (b.description) { %>
                    <p class="mt-3 max-w-[580px] text-[13px] text-zinc-100 md:text-[15px]">
                      <%= b.description %>
                    </p>
                    <% } %>
                      <a href="<%= b.product_id ? ('/products/' + b.product_id) : '/products' %>"
                        class="mt-5 inline-flex h-10 items-center border border-white px-4 text-[11px] font-bold uppercase tracking-wide text-white hover:bg-white hover:text-black">
                        Shop Now
                      </a>
                </div>
              </div>
            </div>
          </div>
          <% }) %>
            <% } else { %>
              <div class="hero-slide absolute inset-0 opacity-100 z-10">
                <div class="absolute inset-0 bg-zinc-700"></div>
                <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
                <div class="relative h-full">
                  <div class="absolute bottom-8 left-0 w-full px-4 lg:bottom-12 lg:px-[140px]">
                    <div class="max-w-[700px] text-white">
                      <h1 class="font-serif text-[30px] leading-tight md:text-[56px]">Spring / Summer 2026</h1>
                      <p class="mt-3 max-w-[580px] text-[13px] text-zinc-100 md:text-[15px]">Discover the latest MAISON
                        collection and elevate your wardrobe.</p>
                      <a href="/products"
                        class="mt-5 inline-flex h-10 items-center border border-white px-4 text-[11px] font-bold uppercase tracking-wide text-white hover:bg-white hover:text-black">
                        Shop Now
                      </a>
                    </div>
                  </div>
                </div>
              </div>
              <% } %>
                <% if (banners && banners.length> 1) { %>
                  <div class="absolute bottom-4 right-4 z-30 flex gap-2">
                    <button id="slide-prev"
                      class="inline-flex h-9 w-9 items-center justify-center border border-white/70 bg-black/55 text-white hover:bg-black/75">‹</button>
                    <button id="slide-next"
                      class="inline-flex h-9 w-9 items-center justify-center border border-white/70 bg-black/55 text-white hover:bg-black/75">›</button>
                  </div>
                  <% } %>
    </section>

    <!-- New Arrivals Section -->
    <section class="py-16">
      <div class="mx-auto max-w-[1440px] px-4 lg:px-[140px]">
        <div class="mb-8">
          <p class="text-[11px] font-bold text-[#737373]">NEW ARRIVALS</p>
          <div class="mt-2 h-px w-[1160px] bg-[#e0e0e0]"></div>
        </div>

        <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4">
          <% if (newArrivals && newArrivals.length> 0) { %>
            <% newArrivals.forEach(product=> { %>
              <a href="/products/<%= product.id %>" class="group cursor-pointer">
                <div class="aspect-square bg-[#f5f5f5] mb-4 overflow-hidden">
                  <% if (product.primary_image) { %>
                    <img src="<%= product.primary_image %>" alt="<%= product.name %>"
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
                    <% } %>
                </div>
                <p class="text-[13px] font-normal mb-1">
                  <%= product.name %>
                </p>
                <p class="text-[13px] text-[#737373]">$<%= Number(product.price || 0).toFixed(2) %>
                </p>
              </a>
              <% }) %>
                <% } else { %>
                  <p class="text-[13px] text-[#737373]">No items to show.</p>
                  <% } %>
        </div>
      </div>
    </section>

    <!-- The Edit Section -->
    <section class="bg-[#f5f5f5] py-16">
      <div class="mx-auto max-w-[1440px] px-4 lg:px-[140px]">
        <div class="mb-8">
          <p class="text-[11px] font-bold text-[#737373]">THE EDIT</p>
          <div class="mt-2 h-px w-[1160px] bg-[#e0e0e0]"></div>
        </div>

        <!-- <div class="grid grid-cols-1 gap-8 lg:grid-cols-2">
          <div class="aspect-[560/320] bg-[#f5f5f5] border border-[#e0e0e0]">
            <p class="absolute bottom-4 left-1/2 -translate-x-1/2 text-[10px] text-[#737373]">Editorial 1</p>
          </div>

          <div class="space-y-8">
            <div class="aspect-[440/148] bg-[#f5f5f5] border border-[#e0e0e0]">
              <p class="absolute bottom-4 left-1/2 -translate-x-1/2 text-[10px] text-[#737373]">Editorial 2</p>
            </div>
            <div class="aspect-[440/148] bg-[#f5f5f5] border border-[#e0e0e0]">
              <p class="absolute bottom-4 left-1/2 -translate-x-1/2 text-[10px] text-[#737373]">Editorial 3</p>
            </div>
          </div>
        </div> -->

        <div class="mt-16 text-center">
          <h2 class="font-serif text-[24px] font-normal">The New Classics</h2>
          <p class="mt-4 text-[13px] text-[#737373]">Elevated everyday essentials for the modern wardrobe.</p>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="border-t border-[#e0e0e0] bg-white">
      <div class="mx-auto max-w-[1440px] px-4 py-8 lg:px-[140px]">
        <div class="grid gap-8 md:grid-cols-3">
          <div>
            <p class="font-serif text-[16px] font-normal">MAISON</p>
            <p class="mt-2 text-[11px] text-[#737373]">Luxury since 2026</p>
          </div>
          <div>
            <p class="text-[11px] font-bold">EXPLORE</p>
            <div class="mt-2 space-y-1 text-[11px] text-[#737373]">
              <a href="/products?category=women" class="block hover:text-black">Women</a>
              <a href="/products?category=men" class="block hover:text-black">Men</a>
              <a href="/products?category=kids" class="block hover:text-black">Kids</a>
            </div>
          </div>
          <div>
            <p class="text-[11px] font-bold">ACCOUNT</p>
            <div class="mt-2 space-y-1 text-[11px] text-[#737373]">
              <% if (user) { %>
                <a href="/profile" class="block hover:text-black">My Account</a>
                <a href="/orders" class="block hover:text-black">Orders</a>
                <a href="/logout" class="block hover:text-black">Sign Out</a>
                <% } else { %>
                  <a href="/login" class="block hover:text-black">Sign In</a>
                  <a href="/register" class="block hover:text-black">Register</a>
                  <% } %>
            </div>
          </div>
        </div>
        <div class="mt-8 border-t border-[#e0e0e0] pt-6">
          <p class="text-[10px] text-[#737373]">© 2026 MAISON. All rights reserved.</p>
        </div>
      </div>
    </footer>
    <%- include('../partials/clientScripts') %>
</body>

</html>