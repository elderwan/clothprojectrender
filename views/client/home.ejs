<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | MAISON</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-white text-black">
  <!-- Header -->
  <header class="border-b border-[#e0e0e0] bg-white">
    <div class="mx-auto h-[76px] max-w-[1440px] px-4 lg:px-[140px]">
      <div class="flex h-full items-center justify-between">
        <a href="/" class="font-serif text-[20px] font-normal">MAISON</a>
        <nav class="flex items-center gap-6 text-[11px] font-bold">
          <a href="/products?category=women" class="hover:text-gray-600">WOMEN</a>
          <a href="/products?category=men" class="hover:text-gray-600">MEN</a>
          <a href="/products?category=kids" class="hover:text-gray-600">KIDS</a>
          <a href="/cart" class="hover:text-gray-600">Cart<% if (cartCount > 0) { %> (<%= cartCount %>)<% } %></a>
          <% if (user) { %>
            <a href="/profile" class="hover:text-gray-600">Account</a>
          <% } else { %>
            <a href="/login" class="hover:text-gray-600">Account</a>
          <% } %>
          <a href="/products" class="hover:text-gray-600">Search</a>
        </nav>
      </div>
    </div>
  </header>

  <!-- Hero Section -->
  <section class="relative h-[580px] bg-[#f5f5f5]">
    <div class="mx-auto max-w-[1440px] px-4 lg:px-[140px]">
      <div class="flex h-full flex-col justify-center">
        <div class="max-w-md">
          <p class="mb-4 text-[11px] font-bold text-white">NEW COLLECTION</p>
          <h1 class="mb-8 font-serif text-[48px] leading-none text-white">Spring / Summer 2026</h1>
          <a href="/products" class="inline-block border border-white px-4 py-2 text-[11px] font-bold text-white hover:bg-white hover:text-black">
            DISCOVER
          </a>
        </div>
      </div>
    </div>
    <p class="absolute bottom-8 left-1/2 -translate-x-1/2 text-[10px] text-[#737373]">Hero Campaign</p>
  </section>

  <!-- New Arrivals Section -->
  <section class="py-16">
    <div class="mx-auto max-w-[1440px] px-4 lg:px-[140px]">
      <div class="mb-8">
        <p class="text-[11px] font-bold text-[#737373]">NEW ARRIVALS</p>
        <div class="mt-2 h-px w-[1160px] bg-[#e0e0e0]"></div>
      </div>

      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4">
        <!-- Product 1 -->
        <div class="group">
          <div class="aspect-square bg-[#f5f5f5] mb-4"></div>
          <p class="text-[13px] font-normal">Cashmere Coat</p>
          <p class="text-[13px] text-[#737373]">$285.00</p>
        </div>

        <!-- Product 2 -->
        <div class="group">
          <div class="aspect-square bg-[#f5f5f5] mb-4"></div>
          <p class="text-[13px] font-normal">Silk Blouse</p>
          <p class="text-[13px] text-[#737373]">$165.00</p>
        </div>

        <!-- Product 3 -->
        <div class="group">
          <div class="aspect-square bg-[#f5f5f5] mb-4"></div>
          <p class="text-[13px] font-normal">Wide Trousers</p>
          <p class="text-[13px] text-[#737373]">$195.00</p>
        </div>

        <!-- Product 4 -->
        <div class="group">
          <div class="aspect-square bg-[#f5f5f5] mb-4"></div>
          <p class="text-[13px] font-normal">Wool Blazer</p>
          <p class="text-[13px] text-[#737373]">$245.00</p>
        </div>
      </div>
    </div>
  </section>

  <!-- The Edit Section -->
  <section class="bg-[#f5f5f5] py-16">
    <div class="mx-auto max-w-[1440px] px-4 lg:px-[140px]">
      <div class="mb-8">
        <p class="text-[11px] font-bold text-[#737373]">THE EDIT</p>
        <div class="mt-2 h-px w-[1160px] bg-[#e0e0e0]"></div>
      </div>

      <div class="grid grid-cols-1 gap-8 lg:grid-cols-2">
        <!-- Editorial 1 -->
        <div class="aspect-[560/320] bg-[#f5f5f5] border border-[#e0e0e0]">
          <p class="absolute bottom-4 left-1/2 -translate-x-1/2 text-[10px] text-[#737373]">Editorial 1</p>
        </div>

        <!-- Editorial 2 & 3 -->
        <div class="space-y-8">
          <div class="aspect-[440/148] bg-[#f5f5f5] border border-[#e0e0e0]">
            <p class="absolute bottom-4 left-1/2 -translate-x-1/2 text-[10px] text-[#737373]">Editorial 2</p>
          </div>
          <div class="aspect-[440/148] bg-[#f5f5f5] border border-[#e0e0e0]">
            <p class="absolute bottom-4 left-1/2 -translate-x-1/2 text-[10px] text-[#737373]">Editorial 3</p>
          </div>
        </div>
      </div>

      <div class="mt-16 text-center">
        <h2 class="font-serif text-[24px] font-normal">The New Classics</h2>
        <p class="mt-4 text-[13px] text-[#737373]">Elevated everyday essentials for the modern wardrobe.</p>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-[#e0e0e0] bg-white">
    <div class="mx-auto max-w-[1440px] px-4 py-8 lg:px-[140px]">
      <div class="grid gap-8 md:grid-cols-3">
        <div>
          <p class="font-serif text-[16px] font-normal">MAISON</p>
          <p class="mt-2 text-[11px] text-[#737373]">Luxury since 2026</p>
        </div>
        <div>
          <p class="text-[11px] font-bold">EXPLORE</p>
          <div class="mt-2 space-y-1 text-[11px] text-[#737373]">
            <a href="/products?category=women" class="block hover:text-black">Women</a>
            <a href="/products?category=men" class="block hover:text-black">Men</a>
            <a href="/products?category=kids" class="block hover:text-black">Kids</a>
          </div>
        </div>
        <div>
          <p class="text-[11px] font-bold">ACCOUNT</p>
          <div class="mt-2 space-y-1 text-[11px] text-[#737373]">
            <% if (user) { %>
              <a href="/profile" class="block hover:text-black">My Account</a>
              <a href="/orders" class="block hover:text-black">Orders</a>
              <a href="/logout" class="block hover:text-black">Sign Out</a>
            <% } else { %>
              <a href="/login" class="block hover:text-black">Sign In</a>
              <a href="/register" class="block hover:text-black">Register</a>
            <% } %>
          </div>
        </div>
      </div>
      <div class="mt-8 border-t border-[#e0e0e0] pt-6">
        <p class="text-[10px] text-[#737373]">© 2026 MAISON. All rights reserved.</p>
      </div>
    </div>
  </footer>
</body>
</html>

