<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | MAISON</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-white text-black">
  <!-- Header -->
  <header class="border-b border-[#e0e0e0] bg-white">
    <div class="mx-auto h-[76px] max-w-[1440px] px-4 lg:px-[140px]">
      <div class="flex h-full items-center justify-between">
        <a href="/" class="font-serif text-[20px] font-normal">MAISON</a>
        <nav class="flex items-center gap-6 text-[11px] font-bold">
          <a href="/products" class="hover:text-gray-600">Shop</a>
          <a href="/cart" class="hover:text-gray-600">Cart</a>
          <% if (user) { %>
            <a href="/profile" class="hover:text-gray-600">Account</a>
          <% } else { %>
            <a href="/login" class="hover:text-gray-600">Sign In</a>
          <% } %>
        </nav>
      </div>
    </div>
  </header>

  <!-- Main Content -->
  <main class="mx-auto flex min-h-[calc(100vh-76px)] max-w-[1440px] items-center justify-center px-4 py-20">
    <section class="w-full max-w-[440px]">
      <h1 class="text-center font-serif text-[20px] font-normal">MAISON</h1>
      <div class="mt-4 border-t border-[#e0e0e0]"></div>

      <h2 class="mt-6 text-[18px] font-bold">CREATE ACCOUNT</h2>
      <p class="mt-2 text-[13px] text-[#737373]">Join MAISON today</p>

      <% if (error) { %>
        <div class="mt-4 border border-red-300 bg-red-50 px-3 py-2 text-[13px] text-red-700">
          <%= error %>
        </div>
      <% } %>

      <form method="POST" action="/register" class="mt-6 space-y-4">
        <div>
          <label for="full_name" class="mb-2 block text-[10px] text-[#737373]">Full Name</label>
          <input
            id="full_name"
            type="text"
            name="full_name"
            required
            class="h-11 w-full border border-[#e0e0e0] px-3 text-[13px]"
            placeholder="John Doe"
          />
        </div>

        <div>
          <label for="email" class="mb-2 block text-[10px] text-[#737373]">Email Address</label>
          <input
            id="email"
            type="email"
            name="email"
            required
            class="h-11 w-full border border-[#e0e0e0] px-3 text-[13px]"
            placeholder="your@email.com"
          />
        </div>

        <div>
          <label for="password" class="mb-2 block text-[10px] text-[#737373]">Password</label>
          <input
            id="password"
            type="password"
            name="password"
            required
            class="h-11 w-full border border-[#e0e0e0] px-3 text-[13px]"
            placeholder="••••••••"
          />
        </div>

        <div>
          <label for="confirm_password" class="mb-2 block text-[10px] text-[#737373]">Confirm Password</label>
          <input
            id="confirm_password"
            type="password"
            name="confirm_password"
            required
            class="h-11 w-full border border-[#e0e0e0] px-3 text-[13px]"
            placeholder="••••••••"
          />
        </div>

        <button type="submit" class="h-[52px] w-full border border-black bg-black text-[11px] font-bold text-white hover:bg-zinc-800">
          CREATE ACCOUNT
        </button>
      </form>

      <div class="mt-6 border-t border-[#e0e0e0]"></div>

      <p class="mt-4 text-[13px] text-[#737373]">Already a member?</p>
      <a href="/login" class="mt-2 inline-block text-[13px] font-bold text-black hover:text-gray-600">
        Sign In
      </a>
    </section>
  </main>

  <!-- Footer -->
  <footer class="border-t border-[#e0e0e0] bg-white">
    <div class="mx-auto max-w-[1440px] px-4 py-8 lg:px-[140px]">
      <div class="grid gap-8 md:grid-cols-3">
        <div>
          <p class="font-serif text-[16px] font-normal">MAISON</p>
          <p class="mt-2 text-[11px] text-[#737373]">Luxury since 2026</p>
        </div>
        <div>
          <p class="text-[11px] font-bold">EXPLORE</p>
          <div class="mt-2 space-y-1 text-[11px] text-[#737373]">
            <a href="/products" class="block hover:text-black">Women</a>
            <a href="/products" class="block hover:text-black">Men</a>
            <a href="/products" class="block hover:text-black">Kids</a>
          </div>
        </div>
        <div>
          <p class="text-[11px] font-bold">ACCOUNT</p>
          <div class="mt-2 space-y-1 text-[11px] text-[#737373]">
            <a href="/login" class="block hover:text-black">Sign In</a>
            <a href="/register" class="block hover:text-black">Register</a>
            <a href="/orders" class="block hover:text-black">Orders</a>
          </div>
        </div>
      </div>
      <div class="mt-8 border-t border-[#e0e0e0] pt-6">
        <p class="text-[10px] text-[#737373]">© 2026 MAISON. All rights reserved.</p>
      </div>
    </div>
  </footer>
</body>
</html>

