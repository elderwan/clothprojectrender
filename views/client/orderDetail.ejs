<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | MAISON</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }
    h1, .font-serif { font-family: 'Georgia', serif; }
  </style>
</head>
<body class="bg-white text-black pb-[60px] lg:pb-0">
  <!-- Header -->
  <%- include('../partials/header', { user, cartCount }) %>  

  <!-- Main Content -->
  <main class="mx-auto max-w-[1440px] px-5 py-8 lg:px-[140px] lg:py-[60px]">
    <div class="flex items-center gap-4 mb-6">
      <a href="/orders" class="text-[11px] font-bold uppercase hover:underline">← Back to Orders</a>
    </div>

    <h1 class="text-[24px] lg:text-[36px] font-normal mb-1 lg:mb-2 uppercase font-serif">Order Details</h1>
    <p class="text-[11px] text-[#737373] mb-8 lg:mb-10 uppercase tracking-widest">
      Order #<%= order.id.slice(0, 8).toUpperCase() %> — <%= new Date(order.created_at).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %>
    </p>
    <div class="h-px w-full bg-[#e0e0e0] mb-8 lg:mb-10"></div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      <!-- Order Items -->
      <div class="lg:col-span-8">
        <p class="text-[10px] lg:text-[11px] font-bold mb-4 uppercase tracking-wider">Items</p>
        <div class="h-px w-full bg-[#e0e0e0] mb-5"></div>

        <div class="space-y-8">
          <% order.items.forEach(item => { %>
            <div class="flex gap-5 lg:gap-8 pb-8 border-b border-[#e0e0e0] last:border-0">
              <div class="w-[80px] h-[100px] lg:w-[100px] lg:h-[125px] bg-[#f5f5f5] flex-shrink-0">
                <!-- Placeholder for product image if available in join -->
              </div>
              <div class="flex-1">
                <p class="text-[9px] lg:text-[10px] font-bold text-[#737373] uppercase mb-1">Maison</p>
                <p class="text-[13px] lg:text-[15px] font-normal mb-1"><%= item.product_name %></p>
                <p class="text-[11px] lg:text-[12px] text-[#737373] mb-2">Size: <%= item.size || 'M' %>  |  Qty: <%= item.quantity %></p>
                <p class="text-[13px] lg:text-[14px] font-normal">$<%= Number(item.unit_price).toFixed(2) %></p>
              </div>
            </div>
          <% }) %>
        </div>
      </div>

      <!-- Order Summary & Shipping -->
      <div class="lg:col-span-4 space-y-10">
        <!-- Status -->
        <div>
          <p class="text-[10px] lg:text-[11px] font-bold mb-4 uppercase tracking-wider">Order Status</p>
          <div class="h-px w-full bg-[#e0e0e0] mb-5"></div>
          <div class="bg-[#f5f5f5] p-4">
            <p class="text-[12px] font-bold uppercase tracking-widest"><%= order.status %></p>
          </div>
        </div>

        <!-- Summary -->
        <div>
          <p class="text-[10px] lg:text-[11px] font-bold mb-4 uppercase tracking-wider">Summary</p>
          <div class="h-px w-full bg-[#e0e0e0] mb-5"></div>
          <div class="space-y-4">
            <div class="flex justify-between">
              <span class="text-[12px]">Subtotal</span>
              <span class="text-[12px]">$<%= Number(order.total_amount).toFixed(2) %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-[12px]">Shipping</span>
              <span class="text-[12px]">Complimentary</span>
            </div>
            <div class="flex justify-between">
              <span class="text-[12px]">Tax (10%)</span>
              <span class="text-[12px]">$<%= (Number(order.total_amount) * 0.1).toFixed(2) %></span>
            </div>
            <div class="h-px w-full bg-[#e0e0e0] my-2"></div>
            <div class="flex justify-between items-baseline">
              <span class="text-[14px] font-bold uppercase">Total</span>
              <span class="text-[16px] font-bold">$<%= (Number(order.total_amount) * 1.1).toFixed(2) %></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <!-- Footer -->
  <footer class="border-t border-[#e0e0e0] bg-white mt-16 pb-[60px] lg:pb-0">
    <div class="mx-auto max-w-[1440px] px-5 py-12 lg:px-[140px]">
      <div class="flex flex-col lg:flex-row justify-between gap-12">
        <div class="lg:w-1/3">
          <p class="font-serif text-[16px] font-normal mb-4">MAISON</p>
          <p class="text-[11px] text-[#737373]">Luxury since 2026</p>
        </div>
        <div class="lg:w-1/3 text-left lg:text-right ml-auto">
          <p class="text-[11px] font-bold mb-4 uppercase">Account</p>
          <div class="flex gap-4 lg:justify-end">
            <a href="/profile" class="text-[11px] text-[#737373] hover:text-black">My Account</a>
            <a href="/orders" class="text-[11px] text-[#737373] hover:text-black">Order History</a>
          </div>
        </div>
      </div>
      <div class="mt-16 pt-8 border-t border-[#e0e0e0]">
        <p class="text-[10px] text-[#737373]">© 2026 MAISON. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <!-- Bottom Nav -->
  <%- include('../partials/bottomNav', { title }) %>
</body>
</html>
