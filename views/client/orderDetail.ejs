<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | MAISON</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-white text-black">
  <!-- Header -->
  <header class="border-b border-[#e0e0e0] bg-white">
    <div class="mx-auto h-[76px] max-w-[1440px] px-4 lg:px-[140px]">
      <div class="flex h-full items-center justify-between">
        <a href="/" class="font-serif text-[20px] font-normal">MAISON</a>
        <nav class="flex items-center gap-6 text-[11px] font-bold">
          <a href="/products?category=women" class="hover:text-gray-600">WOMEN</a>
          <a href="/products?category=men" class="hover:text-gray-600">MEN</a>
          <a href="/products?category=kids" class="hover:text-gray-600">KIDS</a>
          <a href="/cart" class="hover:text-gray-600">Cart<% if (cart && cart.items && cart.items.length > 0) { %> (<%= cart.items.length %>)<% } %></a>
          <% if (user) { %>
            <a href="/profile" class="hover:text-gray-600">Account</a>
          <% } else { %>
            <a href="/login" class="hover:text-gray-600">Account</a>
          <% } %>
          <a href="#" class="hover:text-gray-600">Search</a>
        </nav>
      </div>
    </div>
  </header>

  <!-- Main Content -->
  <main class="mx-auto max-w-[1440px] px-4 py-8 lg:px-[140px]">
    <div class="flex items-center gap-4 mb-4">
      <a href="/orders" class="text-[11px] text-[#737373] hover:text-black">← Back to Orders</a>
    </div>

    <h1 class="font-serif text-[36px] font-normal mb-4">ORDER #<%= order.id %></h1>
    <p class="text-[12px] text-[#737373] mb-6">Placed on <%= new Date(order.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></p>
    <div class="h-px w-full bg-[#e0e0e0] mb-8"></div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Order Items -->
      <div class="lg:col-span-2 space-y-6">
        <div>
          <p class="text-[11px] font-bold mb-4">ORDER ITEMS</p>
          <div class="h-px w-full bg-[#e0e0e0] mb-4"></div>

          <div class="space-y-6">
            <% if (order.items && order.items.length > 0) { %>
              <% order.items.forEach(item => { %>
                <div class="flex gap-6 pb-6 border-b border-[#e0e0e0]">
                  <div class="w-[120px] h-[150px] bg-[#f5f5f5] flex-shrink-0">
                    <% if (item.product_image) { %>
                      <img src="<%= item.product_image %>" alt="<%= item.product_name %>" class="w-full h-full object-cover" />
                    <% } %>
                  </div>
                  <div class="flex-1">
                    <p class="text-[10px] font-bold text-[#737373] mb-2">MAISON</p>
                    <p class="text-[15px] font-normal mb-2"><%= item.product_name %></p>
                    <p class="text-[12px] text-[#737373] mb-4">Size: <%= item.size || 'M' %>   Colour: Black</p>
                    <div class="flex justify-between items-center">
                      <p class="text-[14px] font-normal">Qty: <%= item.quantity %></p>
                      <p class="text-[14px] font-normal">$<%= Number(item.price || 0).toFixed(2) %></p>
                    </div>
                  </div>
                </div>
              <% }) %>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Order Summary -->
      <div class="space-y-6">
        <div>
          <p class="text-[11px] font-bold mb-4">ORDER SUMMARY</p>
          <div class="h-px w-full bg-[#e0e0e0] mb-4"></div>

          <div class="space-y-4">
            <div class="flex justify-between">
              <span class="text-[12px]">Subtotal</span>
              <span class="text-[12px]">$<%= Number(order.subtotal || 0).toFixed(2) %></span>
            </div>
            <div class="flex justify-between">
              <span class="text-[12px]">Shipping</span>
              <span class="text-[12px]">Complimentary</span>
            </div>
            <div class="flex justify-between">
              <span class="text-[12px]">Tax (10%)</span>
              <span class="text-[12px]">$<%= Number((order.subtotal || 0) * 0.1).toFixed(2) %></span>
            </div>
            <div class="h-px w-full bg-[#e0e0e0] my-4"></div>
            <div class="flex justify-between">
              <span class="text-[16px] font-bold">Total</span>
              <span class="text-[16px] font-bold">$<%= Number(order.total || 0).toFixed(2) %></span>
            </div>
          </div>
        </div>

        <!-- Order Status -->
        <div>
          <p class="text-[11px] font-bold mb-4">ORDER STATUS</p>
          <div class="h-px w-full bg-[#e0e0e0] mb-4"></div>

          <div class="space-y-2">
            <div class="flex justify-between">
              <span class="text-[12px]">Status</span>
              <span class="text-[12px] font-bold"><%= order.status %></span>
            </div>
            <% if (order.tracking_number) { %>
              <div class="flex justify-between">
                <span class="text-[12px]">Tracking</span>
                <span class="text-[12px]"><%= order.tracking_number %></span>
              </div>
            <% } %>
          </div>
        </div>

        <!-- Shipping Address -->
        <% if (order.shipping_address) { %>
          <div>
            <p class="text-[11px] font-bold mb-4">SHIPPING ADDRESS</p>
            <div class="h-px w-full bg-[#e0e0e0] mb-4"></div>

            <div class="text-[12px]">
              <p class="font-bold mb-1"><%= order.shipping_address.full_name %></p>
              <p class="text-[#737373] mb-1"><%= order.shipping_address.street_address %></p>
              <p class="text-[#737373] mb-1"><%= order.shipping_address.city %>, <%= order.shipping_address.state %> <%= order.shipping_address.zip_code %></p>
              <p class="text-[#737373]"><%= order.shipping_address.country %></p>
            </div>
          </div>
        <% } %>

        <!-- Actions -->
        <div class="space-y-3">
          <% if (order.status === 'Delivered') { %>
            <button class="w-full border border-black px-6 py-3 text-[11px] font-bold text-black hover:bg-black hover:text-white">
              REORDER ITEMS
            </button>
          <% } %>
          <button class="w-full border border-black px-6 py-3 text-[11px] font-bold text-black hover:bg-black hover:text-white">
            DOWNLOAD INVOICE
          </button>
          <a href="/contact" class="block w-full border border-black px-6 py-3 text-[11px] font-bold text-black hover:bg-black hover:text-white text-center">
            NEED HELP?
          </a>
        </div>
      </div>
    </div>
  </main>

  <!-- Footer -->
  <footer class="border-t border-[#e0e0e0] bg-white mt-16">
    <div class="mx-auto max-w-[1440px] px-4 py-8 lg:px-[140px]">
      <div class="grid gap-8 md:grid-cols-3">
        <div>
          <p class="font-serif text-[16px] font-normal">MAISON</p>
          <p class="mt-2 text-[11px] text-[#737373]">Luxury since 2026</p>
        </div>
        <div>
          <p class="text-[11px] font-bold">EXPLORE</p>
          <div class="mt-2 space-y-1 text-[11px] text-[#737373]">
            <a href="/products?category=women" class="block hover:text-black">Women</a>
            <a href="/products?category=men" class="block hover:text-black">Men</a>
            <a href="/products?category=kids" class="block hover:text-black">Kids</a>
          </div>
        </div>
        <div>
          <p class="text-[11px] font-bold">ACCOUNT</p>
          <div class="mt-2 space-y-1 text-[11px] text-[#737373]">
            <% if (user) { %>
              <a href="/profile" class="block hover:text-black">My Account</a>
              <a href="/orders" class="block hover:text-black">Orders</a>
              <a href="/logout" class="block hover:text-black">Sign Out</a>
            <% } else { %>
              <a href="/login" class="block hover:text-black">Sign In</a>
              <a href="/register" class="block hover:text-black">Register</a>
            <% } %>
          </div>
        </div>
      </div>
      <div class="mt-8 border-t border-[#e0e0e0] pt-6">
        <p class="text-[10px] text-[#737373]">© 2026 MAISON. All rights reserved.</p>
      </div>
    </div>
  </footer>
</body>
</html>
