<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | MAISON</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-white text-black">
  <!-- Header -->
  <%- include('../partials/header', { user, cartCount }) %>  

  <!-- Main Content -->
  <main class="mx-auto max-w-[1440px] px-4 py-8 lg:px-[140px]">
    <h1 class="font-serif text-[36px] font-normal mb-4">SHOPPING BAG</h1>
    <p class="text-[11px] text-[#737373] mb-6">
      <% if (cart && cart.items && cart.items.length > 0) { %>
        <%= cart.items.length %> item<%= cart.items.length > 1 ? 's' : '' %>
      <% } else { %>
        0 items
      <% } %>
    </p>
    <div class="h-px w-full bg-[#e0e0e0] mb-8"></div>

    <% if (cart && cart.items && cart.items.length > 0) { %>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Cart Items -->
        <div class="lg:col-span-2 space-y-6">
          <% cart.items.forEach(item => { %>
            <div class="flex gap-6 pb-6 border-b border-[#e0e0e0]">
              <div class="w-[120px] h-[150px] bg-[#f5f5f5] flex-shrink-0">
                <% if (item.product_image) { %>
                  <img src="<%= item.product_image %>" alt="<%= item.product_name %>" class="w-full h-full object-cover" />
                <% } %>
              </div>
              <div class="flex-1">
                <p class="text-[10px] font-bold text-[#737373] mb-2">MAISON</p>
                <p class="text-[15px] font-normal mb-2"><%= item.product_name %></p>
                <p class="text-[12px] text-[#737373] mb-4">Size: <%= item.size || 'M' %>   Colour: Black</p>
                <p class="text-[14px] font-normal mb-4">$<%= Number(item.price || 0).toFixed(2) %></p>

                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-2">
                    <p class="text-[11px] text-[#737373]">Qty:</p>
                    <div class="flex items-center">
                      <form method="POST" action="/cart/update" class="inline">
                        <input type="hidden" name="id" value="<%= item.id %>" />
                        <input type="hidden" name="quantity" value="<%= Math.max(1, Number(item.quantity || 1) - 1) %>" />
                        <button type="submit" class="w-[36px] h-[36px] border border-[#e0e0e0] flex items-center justify-center text-[16px]">-</button>
                      </form>
                      <span class="w-[20px] text-center text-[13px]"><%= item.quantity %></span>
                      <form method="POST" action="/cart/update" class="inline">
                        <input type="hidden" name="id" value="<%= item.id %>" />
                        <input type="hidden" name="quantity" value="<%= Number(item.quantity || 1) + 1 %>" />
                        <button type="submit" class="w-[36px] h-[36px] border border-[#e0e0e0] flex items-center justify-center text-[16px]">+</button>
                      </form>
                    </div>
                  </div>
                  <form method="POST" action="/cart/remove/<%= item.id %>" class="inline">
                    <button type="submit" class="text-[11px] text-[#737373] hover:text-black">Remove</button>
                  </form>
                </div>
              </div>
            </div>
          <% }) %>
        </div>

        <!-- Order Summary -->
        <div class="space-y-6">
          <div>
            <p class="text-[11px] font-bold mb-4">ORDER SUMMARY</p>
            <div class="h-px w-full bg-[#e0e0e0] mb-4"></div>

            <div class="space-y-4">
              <div class="flex justify-between">
                <span class="text-[12px]">Subtotal</span>
                <span class="text-[12px]">$<%= Number(cart.subtotal || 0).toFixed(2) %></span>
              </div>
              <div class="flex justify-between">
                <span class="text-[12px]">Shipping</span>
                <span class="text-[12px]">Complimentary</span>
              </div>
              <div class="flex justify-between">
                <span class="text-[12px]">Tax (10%)</span>
                <span class="text-[12px]">$<%= Number((cart.subtotal || 0) * 0.1).toFixed(2) %></span>
              </div>
              <div class="h-px w-full bg-[#e0e0e0] my-4"></div>
              <div class="flex justify-between">
                <span class="text-[16px] font-bold">Total</span>
                <span class="text-[16px] font-bold">$<%= Number(cart.total || 0).toFixed(2) %></span>
              </div>
            </div>

            <form method="POST" action="/orders">
              <button type="submit" class="w-full h-[52px] border border-black bg-black text-[11px] font-bold text-white hover:bg-zinc-800 mt-6">
                CONFIRM ORDER
              </button>
            </form>

            <p class="text-[11px] text-[#737373] mt-4">Complimentary delivery on orders above $200</p>
          </div>
        </div>
      </div>
    <% } else { %>
      <div class="text-center py-16">
        <p class="text-[13px] text-[#737373] mb-4">Your shopping bag is empty.</p>
        <a href="/products" class="inline-block border border-black px-6 py-3 text-[11px] font-bold text-black hover:bg-black hover:text-white">
          CONTINUE SHOPPING
        </a>
      </div>
    <% } %>
  </main>

  <!-- Footer -->
  <footer class="border-t border-[#e0e0e0] bg-white mt-16">
    <div class="mx-auto max-w-[1440px] px-4 py-8 lg:px-[140px]">
      <div class="grid gap-8 md:grid-cols-3">
        <div>
          <p class="font-serif text-[16px] font-normal">MAISON</p>
          <p class="mt-2 text-[11px] text-[#737373]">Luxury since 2026</p>
        </div>
        <div>
          <p class="text-[11px] font-bold">EXPLORE</p>
          <div class="mt-2 space-y-1 text-[11px] text-[#737373]">
            <a href="/products?category=women" class="block hover:text-black">Women</a>
            <a href="/products?category=men" class="block hover:text-black">Men</a>
            <a href="/products?category=kids" class="block hover:text-black">Kids</a>
          </div>
        </div>
        <div>
          <p class="text-[11px] font-bold">ACCOUNT</p>
          <div class="mt-2 space-y-1 text-[11px] text-[#737373]">
            <% if (user) { %>
              <a href="/profile" class="block hover:text-black">My Account</a>
              <a href="/orders" class="block hover:text-black">Orders</a>
              <a href="/logout" class="block hover:text-black">Sign Out</a>
            <% } else { %>
              <a href="/login" class="block hover:text-black">Sign In</a>
              <a href="/register" class="block hover:text-black">Register</a>
            <% } %>
          </div>
        </div>
      </div>
      <div class="mt-8 border-t border-[#e0e0e0] pt-6">
        <p class="text-[10px] text-[#737373]">© 2026 MAISON. All rights reserved.</p>
      </div>
    </div>
  </footer>
  <%- include('../partials/clientScripts') %>
</body>
</html>

