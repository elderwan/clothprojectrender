<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | MAISON</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }
    h1, .font-serif { font-family: 'Georgia', serif; }
  </style>
</head>
<body class="bg-white text-black pb-[60px] lg:pb-0">
  <!-- Header -->
  <%- include('../partials/header', { user, cartCount: cart && cart.items ? cart.items.length : 0 }) %>  

  <!-- Main Content -->
  <main class="mx-auto max-w-[1440px] px-5 py-8 lg:px-[140px] lg:py-[60px]">
    <h1 class="text-[22px] lg:text-[36px] font-normal mb-1 lg:mb-2 uppercase font-serif">Shopping Bag</h1>
    <p class="text-[11px] text-[#737373] mb-6 lg:mb-8">
      <%= cart && cart.items ? cart.items.length : 0 %> items
    </p>
    <div class="h-px w-full bg-[#e0e0e0] mb-8 lg:mb-10"></div>

    <% if (error) { %>
      <div class="mb-8 p-4 bg-red-50 text-red-600 text-[12px] border border-red-100 uppercase tracking-widest">
        <%= error %>
      </div>
    <% } %>

    <% if (cart && cart.items && cart.items.length > 0) { %>
      <form id="cart-update-form" method="POST" action="/cart/update"></form>
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        <!-- Cart Items -->
        <div class="lg:col-span-8 space-y-8 lg:space-y-10">
          <% cart.items.forEach(item => { %>
            <div
              class="flex gap-5 lg:gap-10 pb-8 lg:pb-10 border-b border-[#e0e0e0] last:border-0 relative cart-line-item"
              data-item-id="<%= item.id %>"
              data-unit-price="<%= Number(item.product_price || 0) %>"
              data-initial-quantity="<%= Number(item.quantity || 1) %>">
              <input form="cart-update-form" type="hidden" name="id" value="<%= item.id %>" />
              <input
                form="cart-update-form"
                type="hidden"
                name="quantity"
                value="<%= Number(item.quantity || 1) %>"
                class="cart-quantity-input"
                data-item-id="<%= item.id %>" />
              <div class="w-[96px] h-[120px] lg:w-[120px] lg:h-[150px] bg-[#f5f5f5] flex-shrink-0">
                <% if (item.product_image) { %>
                  <img src="<%= item.product_image %>" alt="<%= item.product_name %>" class="w-full h-full object-cover" />
                <% } %>
              </div>
              <div class="flex-1">
                <div class="flex justify-between items-start mb-2">
                  <p class="text-[9px] lg:text-[10px] font-bold text-[#737373] uppercase tracking-wider">Maison</p>
                  <form method="POST" action="/cart/remove/<%= item.id %>" class="inline" data-confirm="Remove this item from your shopping bag?">
                    <button type="submit" class="text-[10px] lg:text-[11px] text-[#737373] hover:text-black uppercase">Remove</button>
                  </form>
                </div>
                <p class="text-[13px] lg:text-[15px] font-normal mb-1 lg:mb-2"><%= item.product_name %></p>
                <p class="text-[11px] lg:text-[12px] text-[#737373] mb-3 lg:mb-4">
                  Size: <%= item.size || 'M' %><% if (item.product_category) { %>  |  Category: <%= item.product_category %><% } %>
                </p>
                <p class="text-[13px] lg:text-[14px] font-normal mb-4 lg:mb-6">$<%= Number(item.product_price || 0).toFixed(2) %></p>

                <div class="flex items-center gap-3">
                  <p class="text-[11px] text-[#737373] hidden lg:block">Qty:</p>
                  <div class="flex items-center">
                    <button
                      type="button"
                      class="cart-qty-decrease w-[28px] h-[28px] lg:w-[36px] lg:h-[36px] border border-[#e0e0e0] flex items-center justify-center text-[14px] lg:text-[16px]"
                      data-item-id="<%= item.id %>">-</button>
                    <span class="cart-qty-display w-[30px] lg:w-[40px] text-center text-[12px] lg:text-[13px]" data-item-id="<%= item.id %>"><%= item.quantity %></span>
                    <button
                      type="button"
                      class="cart-qty-increase w-[28px] h-[28px] lg:w-[36px] lg:h-[36px] border border-[#e0e0e0] flex items-center justify-center text-[14px] lg:text-[16px]"
                      data-item-id="<%= item.id %>">+</button>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        </div>

        <!-- Order Summary -->
        <div class="lg:col-span-4">
          <div class="bg-white lg:sticky lg:top-[120px]">
            <p class="text-[11px] font-bold mb-4 lg:mb-5 uppercase tracking-wider">Order Summary</p>
            <div class="h-px w-full bg-[#e0e0e0] mb-5"></div>

            <div class="space-y-4 lg:space-y-6">
              <div class="flex justify-between">
                <span class="text-[12px]">Subtotal</span>
                <span id="cart-subtotal" class="text-[12px]">$<%= Number(cart.subtotal || 0).toFixed(2) %></span>
              </div>
              <div class="flex justify-between">
                <span class="text-[12px]">Shipping</span>
                <span id="cart-shipping" class="text-[12px]"><%= Number(cart.shipping || 0) > 0 ? `$${Number(cart.shipping || 0).toFixed(2)}` : 'Complimentary' %></span>
              </div>
              <div class="flex justify-between">
                <span class="text-[12px]">Tax (10%)</span>
                <span id="cart-tax" class="text-[12px]">$<%= Number((cart.subtotal || 0) * 0.1).toFixed(2) %></span>
              </div>
              <div class="h-px w-full bg-[#e0e0e0] my-2"></div>
              <div class="flex justify-between items-baseline">
                <span class="text-[15px] lg:text-[16px] font-bold uppercase">Total</span>
                <span id="cart-total" class="text-[15px] lg:text-[16px] font-bold">$<%= Number(cart.total || 0).toFixed(2) %></span>
              </div>
            </div>

            <div id="cart-save-panel" class="hidden mt-8 border border-[#e0e0e0] bg-[#fafafa] p-4">
              <p class="text-[11px] font-bold uppercase tracking-wider">Cart updated locally</p>
              <p class="mt-2 text-[11px] text-[#737373]">Your quantity changes are not saved yet. Save the cart before confirming the order.</p>
              <button
                form="cart-update-form"
                type="submit"
                class="mt-4 w-full h-[46px] border border-black bg-black text-[11px] font-bold text-white hover:bg-zinc-800 transition-colors duration-200 uppercase tracking-widest">
                Save Cart
              </button>
            </div>

            <form method="POST" action="/orders" class="mt-8 lg:mt-10">
              <button id="confirm-order-button" type="submit" class="w-full h-[52px] bg-black text-[11px] font-bold text-white hover:bg-zinc-800 transition-colors duration-200 uppercase tracking-widest">
                Confirm Order
              </button>
            </form>

            <p class="text-[11px] text-[#737373] mt-5 text-center lg:text-left">Complimentary delivery on orders above $200</p>
          </div>
        </div>
      </div>
    <% } else { %>
      <div class="text-center py-20">
        <p class="text-[13px] text-[#737373] mb-8">Your shopping bag is empty.</p>
        <a href="/products" class="inline-block border border-black px-12 py-4 text-[11px] font-bold hover:bg-black hover:text-white transition-colors duration-200 uppercase tracking-widest">
          Continue Shopping
        </a>
      </div>
    <% } %>
  </main>

  <!-- Footer -->
  <footer class="border-t border-[#e0e0e0] bg-white mt-16 pb-[60px] lg:pb-0">
    <div class="mx-auto max-w-[1440px] px-5 py-12 lg:px-[140px]">
      <div class="flex flex-col lg:flex-row justify-between gap-12">
        <div class="lg:w-1/3">
          <p class="font-serif text-[16px] font-normal mb-4">MAISON</p>
          <p class="text-[11px] text-[#737373]">Luxury since 2026</p>
        </div>
        <div class="lg:w-1/3">
          <p class="text-[11px] font-bold mb-4 uppercase">Explore</p>
          <div class="flex gap-4">
            <a href="/products?category=women" class="text-[11px] text-[#737373] hover:text-black">Women</a>
            <a href="/products?category=men" class="text-[11px] text-[#737373] hover:text-black">Men</a>
            <a href="/products?category=kids" class="text-[11px] text-[#737373] hover:text-black">Kids</a>
          </div>
        </div>
        <div class="lg:w-1/3 text-left lg:text-right">
          <p class="text-[11px] font-bold mb-4 uppercase">Account</p>
          <div class="flex gap-4 lg:justify-end">
            <a href="/login" class="text-[11px] text-[#737373] hover:text-black">Sign In</a>
            <a href="/register" class="text-[11px] text-[#737373] hover:text-black">Register</a>
            <a href="/profile" class="text-[11px] text-[#737373] hover:text-black">My Account</a>
          </div>
        </div>
      </div>
      <div class="mt-16 pt-8 border-t border-[#e0e0e0]">
        <p class="text-[10px] text-[#737373]">© 2026 MAISON. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <!-- Bottom Nav -->
  <%- include('../partials/bottomNav', { title }) %>
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const items = Array.from(document.querySelectorAll('.cart-line-item'));
      if (!items.length) return;

      const savePanel = document.getElementById('cart-save-panel');
      const confirmOrderButton = document.getElementById('confirm-order-button');
      const subtotalEl = document.getElementById('cart-subtotal');
      const shippingEl = document.getElementById('cart-shipping');
      const taxEl = document.getElementById('cart-tax');
      const totalEl = document.getElementById('cart-total');
      let hasPendingChanges = false;

      function formatMoney(value) {
        return '$' + Number(value).toFixed(2);
      }

      function computeTotals() {
        let subtotal = 0;
        let hasDirtyChange = false;

        items.forEach((item) => {
          const unitPrice = Number(item.getAttribute('data-unit-price') || 0);
          const initialQuantity = Number(item.getAttribute('data-initial-quantity') || 1);
          const quantityInput = item.querySelector('.cart-quantity-input');
          const nextQuantity = Number(quantityInput ? quantityInput.value : initialQuantity);
          subtotal += unitPrice * nextQuantity;
          if (nextQuantity !== initialQuantity) hasDirtyChange = true;
        });

        const shipping = subtotal > 200 ? 0 : 15;
        const tax = subtotal * 0.1;
        const total = subtotal + shipping;

        if (subtotalEl) subtotalEl.textContent = formatMoney(subtotal);
        if (shippingEl) shippingEl.textContent = shipping > 0 ? formatMoney(shipping) : 'Complimentary';
        if (taxEl) taxEl.textContent = formatMoney(tax);
        if (totalEl) totalEl.textContent = formatMoney(total);
        hasPendingChanges = hasDirtyChange;
        if (savePanel) savePanel.classList.toggle('hidden', !hasDirtyChange);
        if (confirmOrderButton) {
          confirmOrderButton.disabled = hasDirtyChange;
          confirmOrderButton.classList.toggle('cursor-not-allowed', hasDirtyChange);
          confirmOrderButton.classList.toggle('bg-zinc-300', hasDirtyChange);
          confirmOrderButton.classList.toggle('text-zinc-500', hasDirtyChange);
          confirmOrderButton.classList.toggle('hover:bg-zinc-300', hasDirtyChange);
          confirmOrderButton.classList.toggle('hover:bg-zinc-800', !hasDirtyChange);
          confirmOrderButton.classList.toggle('bg-black', !hasDirtyChange);
          confirmOrderButton.classList.toggle('text-white', !hasDirtyChange);
        }
      }

      function updateQuantity(itemId, delta) {
        const quantityInput = document.querySelector('.cart-quantity-input[data-item-id="' + itemId + '"]');
        const quantityDisplay = document.querySelector('.cart-qty-display[data-item-id="' + itemId + '"]');
        if (!quantityInput || !quantityDisplay) return;

        const current = Number(quantityInput.value || 1);
        const next = Math.max(1, current + delta);
        quantityInput.value = String(next);
        quantityDisplay.textContent = String(next);
        computeTotals();
      }

      document.querySelectorAll('.cart-qty-decrease').forEach((button) => {
        button.addEventListener('click', function () {
          const itemId = button.getAttribute('data-item-id');
          if (itemId) updateQuantity(itemId, -1);
        });
      });

      document.querySelectorAll('.cart-qty-increase').forEach((button) => {
        button.addEventListener('click', function () {
          const itemId = button.getAttribute('data-item-id');
          if (itemId) updateQuantity(itemId, 1);
        });
      });

      window.addEventListener('beforeunload', function (event) {
        if (!hasPendingChanges) return;
        event.preventDefault();
        event.returnValue = '';
      });
    });
  </script>
</body>
</html>
