<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | MAISON</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }
    h1, .font-serif { font-family: 'Georgia', serif; }
  </style>
</head>
<body class="bg-white text-black pb-[60px] lg:pb-0">
  <!-- Header -->
  <%- include('../partials/header', { user, cartCount }) %>  

  <!-- Main Content -->
  <main class="mx-auto max-w-[1440px] px-5 py-8 lg:px-[140px] lg:py-[60px]">
    <h1 class="text-[24px] lg:text-[36px] font-normal mb-4 lg:mb-6 uppercase font-serif">Order History</h1>
    <div class="h-px w-full bg-[#e0e0e0] mb-8 lg:mb-10"></div>

    <% if (orders && orders.length > 0) { %>
      <!-- Desktop View -->
      <div class="hidden lg:block overflow-x-auto">
        <table class="w-full text-left">
          <thead>
            <tr class="bg-[#f5f5f5] h-[40px]">
              <th class="pl-4 text-[11px] font-bold">Order #</th>
              <th class="text-[11px] font-bold">Date</th>
              <th class="text-[11px] font-bold">Items</th>
              <th class="text-[11px] font-bold">Total</th>
              <th class="text-[11px] font-bold">Status</th>
              <th class="pr-4 text-[11px] font-bold text-right">Action</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-[#e0e0e0]">
            <% orders.forEach(order => { %>
              <tr class="h-[60px]">
                <td class="pl-4 text-[12px]">#<%= order.id.slice(0, 8).toUpperCase() %></td>
                <td class="text-[12px]"><%= new Date(order.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></td>
                <td class="text-[12px]"><%= order.order_items ? order.order_items.length : 0 %></td>
                <td class="text-[12px]">$<%= Number(order.total_amount).toFixed(2) %></td>
                <td class="text-[12px] capitalize"><%= order.status %></td>
                <td class="pr-4 text-right">
                  <a href="/orders/<%= order.id %>" class="inline-block border border-black px-6 py-1 text-[11px] font-bold hover:bg-black hover:text-white transition-colors duration-200 uppercase">
                    View
                  </a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <!-- Mobile View -->
      <div class="lg:hidden space-y-4">
        <% orders.forEach(order => { %>
          <div class="border border-[#e0e0e0] p-4 flex justify-between items-center">
            <div class="space-y-1">
              <p class="text-[12px] font-bold">#<%= order.id.slice(0, 8).toUpperCase() %></p>
              <p class="text-[11px] text-[#737373]"><%= new Date(order.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></p>
              <p class="text-[12px]">$<%= Number(order.total_amount).toFixed(2) %></p>
              <p class="text-[10px] text-[#737373] capitalize"><%= order.status %></p>
            </div>
            <a href="/orders/<%= order.id %>" class="border border-black px-6 py-3 text-[11px] font-bold hover:bg-black hover:text-white transition-colors duration-200 uppercase">
              View
            </a>
          </div>
        <% }) %>
      </div>

      <!-- Pagination -->
      <% if (totalPages > 1) { %>
        <div class="mt-12 flex gap-2">
          <% for (let i = 1; i <= totalPages; i++) { %>
            <a href="/orders?page=<%= i %>" 
               class="w-[36px] h-[36px] flex items-center justify-center text-[13px] <%= currentPage === i ? 'bg-black text-white' : 'border border-[#e0e0e0] text-black hover:border-black' %>">
              <%= i %>
            </a>
          <% } %>
        </div>
      <% } %>
    <% } else { %>
      <div class="text-center py-20">
        <p class="text-[13px] text-[#737373] mb-6">You haven't placed any orders yet.</p>
        <a href="/products" class="inline-block border border-black px-10 py-4 text-[11px] font-bold hover:bg-black hover:text-white transition-colors duration-200 uppercase">
          Start Shopping
        </a>
      </div>
    <% } %>
  </main>

  <!-- Footer -->
  <footer class="border-t border-[#e0e0e0] bg-white mt-16 pb-[60px] lg:pb-0">
    <div class="mx-auto max-w-[1440px] px-5 py-12 lg:px-[140px]">
      <div class="flex flex-col lg:flex-row justify-between gap-12">
        <div class="lg:w-1/3">
          <p class="font-serif text-[16px] font-normal mb-4">MAISON</p>
          <p class="text-[11px] text-[#737373]">Luxury since 2026</p>
        </div>
        <div class="lg:w-1/3">
          <p class="text-[11px] font-bold mb-4 uppercase">Explore</p>
          <div class="flex gap-4">
            <a href="/products?category=women" class="text-[11px] text-[#737373] hover:text-black">Women</a>
            <a href="/products?category=men" class="text-[11px] text-[#737373] hover:text-black">Men</a>
            <a href="/products?category=kids" class="text-[11px] text-[#737373] hover:text-black">Kids</a>
          </div>
        </div>
        <div class="lg:w-1/3 text-left lg:text-right">
          <p class="text-[11px] font-bold mb-4 uppercase">Account</p>
          <div class="flex gap-4 lg:justify-end">
            <a href="/login" class="text-[11px] text-[#737373] hover:text-black">Sign In</a>
            <a href="/register" class="text-[11px] text-[#737373] hover:text-black">Register</a>
            <a href="/profile" class="text-[11px] text-[#737373] hover:text-black">My Account</a>
          </div>
        </div>
      </div>
      <div class="mt-16 pt-8 border-t border-[#e0e0e0]">
        <p class="text-[10px] text-[#737373]">© 2026 MAISON. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <!-- Bottom Nav -->
  <%- include('../partials/bottomNav', { title }) %>
</body>
</html>
