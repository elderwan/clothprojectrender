<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | MAISON</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }
    h1, .font-serif { font-family: 'Georgia', serif; }
  </style>
</head>
<body class="bg-white text-black pb-[60px] lg:pb-0">
  <!-- Header -->
  <%- include('../partials/header', { user, cartCount }) %>  

  <!-- Main Content -->
  <main class="mx-auto max-w-[1440px] px-5 py-8 lg:px-[140px] lg:py-[60px]">
    <h1 class="text-[24px] lg:text-[36px] font-normal mb-4 lg:mb-6 uppercase font-serif">Order History</h1>
    <div class="h-px w-full bg-[#e0e0e0] mb-8 lg:mb-10"></div>

    <% if (orders && orders.length > 0) { %>
      <!-- Desktop View -->
      <div class="hidden lg:block overflow-x-auto">
        <table class="w-full text-left">
          <thead>
            <tr class="bg-[#f5f5f5] h-[40px]">
              <th class="pl-4 text-[11px] font-bold uppercase">Order #</th>
              <th class="text-[11px] font-bold uppercase">Name</th>
              <th class="text-[11px] font-bold uppercase">Date</th>
              <th class="text-[11px] font-bold uppercase text-center">Items</th>
              <th class="text-[11px] font-bold uppercase">Total</th>
              <th class="text-[11px] font-bold uppercase">Status</th>
              <th class="pr-4 text-[11px] font-bold text-right uppercase">Action</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-[#e0e0e0]">
            <% orders.forEach(order => { %>
              <tr class="hover:bg-[#fafafa] transition-colors duration-150">
                <td class="pl-4 py-6 text-[12px] align-top font-medium">#<%= order.id.slice(0, 8).toUpperCase() %></td>
                <td class="py-6 align-top">
                  <div class="flex flex-col gap-4">
                    <% (order.order_items || []).forEach((item, index) => { %>
                      <div class="flex items-center gap-4">
                        <div class="h-14 w-11 bg-[#f5f5f5] flex-shrink-0 border border-[#eeeeee] overflow-hidden">
                          <% if (item.product_image) { %>
                            <img src="<%= item.product_image %>" alt="<%= item.product_name %>" class="h-full w-full object-cover" />
                          <% } %>
                        </div>
                        <div class="flex flex-col">
                          <span class="text-[11px] font-bold text-black uppercase tracking-tight"><%= item.product_name %></span>
                          <span class="text-[10px] text-[#737373]">Size: <%= item.size || 'M' %> | Qty: <%= item.quantity %></span>
                        </div>
                      </div>
                    <% }) %>
                  </div>
                </td>
                <td class="py-6 text-[12px] align-top whitespace-nowrap"><%= new Date(order.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></td>
                <td class="py-6 text-[12px] align-top text-center">
                  <%= order.order_items.length %> <%= order.order_items.length === 1 ? 'item' : 'items' %>
                </td>
                <td class="py-6 text-[12px] align-top font-bold text-black">$<%= Number(order.total_amount).toFixed(2) %></td>
                <td class="py-6 text-[12px] align-top capitalize"><%= order.status %></td>
                <td class="pr-4 py-6 text-right align-top">
                  <a href="/orders/<%= order.id %>" class="inline-block border border-black px-6 py-1.5 text-[11px] font-bold hover:bg-black hover:text-white transition-colors duration-200 uppercase">
                    View
                  </a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <!-- Mobile View -->
      <div class="lg:hidden space-y-6">
        <% orders.forEach(order => { %>
          <div class="border border-[#e0e0e0] p-5 bg-white">
            <div class="flex justify-between items-start mb-4 pb-3 border-b border-[#f5f5f5]">
              <div>
                <p class="text-[12px] font-bold">#<%= order.id.slice(0, 8).toUpperCase() %></p>
                <p class="text-[11px] text-[#737373] mt-1"><%= new Date(order.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></p>
              </div>
              <p class="text-[12px] font-serif italic text-black uppercase"><%= order.status %></p>
            </div>
            
            <div class="space-y-4">
              <% (order.order_items || []).forEach(item => { %>
                <div class="flex items-center gap-4">
                  <div class="h-14 w-11 bg-[#f5f5f5] border border-[#eeeeee] flex-shrink-0">
                    <% if (item.product_image) { %>
                      <img src="<%= item.product_image %>" alt="<%= item.product_name %>" class="h-full w-full object-cover" />
                    <% } %>
                  </div>
                  <div class="flex-1">
                    <p class="text-[11px] font-bold uppercase leading-tight text-black"><%= item.product_name %></p>
                    <p class="text-[10px] text-[#737373] mt-1">Size: <%= item.size || 'M' %> | Qty: <%= item.quantity %></p>
                  </div>
                </div>
              <% }) %>
            </div>

            <div class="flex justify-between items-center mt-6 pt-4 border-t border-[#f5f5f5]">
              <div>
                <p class="text-[10px] text-[#737373] uppercase mb-1"><%= order.order_items.length %> <%= order.order_items.length === 1 ? 'item' : 'items' %></p>
                <p class="text-[14px] font-bold text-black tracking-tight">$<%= Number(order.total_amount).toFixed(2) %></p>
              </div>
              <a href="/orders/<%= order.id %>" class="border border-black px-6 py-2.5 text-[11px] font-bold hover:bg-black hover:text-white transition-colors duration-200 uppercase tracking-widest">
                View
              </a>
            </div>
          </div>
        <% }) %>
      </div>

      <!-- Pagination -->
      <% if (totalPages > 1) { %>
        <div class="mt-12 flex justify-center gap-2">
          <% for (let i = 1; i <= totalPages; i++) { %>
            <a href="/orders?page=<%= i %>" 
               class="w-[36px] h-[36px] flex items-center justify-center text-[13px] <%= currentPage === i ? 'bg-black text-white' : 'border border-[#e0e0e0] text-black hover:border-black' %>">
              <%= i %>
            </a>
          <% } %>
        </div>
      <% } %>
    <% } else { %>
      <div class="text-center py-20">
        <p class="text-[13px] text-[#737373] mb-6 font-serif italic">You haven't placed any orders yet.</p>
        <a href="/products" class="inline-block border border-black px-10 py-4 text-[11px] font-bold hover:bg-black hover:text-white transition-colors duration-200 uppercase tracking-widest">
          Start Shopping
        </a>
      </div>
    <% } %>
  </main>

  <!-- Footer -->
  <footer class="border-t border-[#e0e0e0] bg-white mt-16 pb-[60px] lg:pb-0">
    <div class="mx-auto max-w-[1440px] px-5 py-12 lg:px-[140px]">
      <div class="flex flex-col lg:flex-row justify-between gap-12">
        <div class="lg:w-1/3 text-center lg:text-left">
          <p class="font-serif text-[16px] font-normal mb-4 tracking-tight">MAISON</p>
          <p class="text-[11px] text-[#737373] uppercase tracking-widest">Luxury since 2026</p>
        </div>
        <div class="lg:w-1/3 text-center lg:text-left">
          <p class="text-[11px] font-bold mb-4 uppercase tracking-[0.2em]">Explore</p>
          <div class="flex justify-center lg:justify-start gap-6">
            <a href="/products?category=women" class="text-[11px] text-[#737373] hover:text-black uppercase">Women</a>
            <a href="/products?category=men" class="text-[11px] text-[#737373] hover:text-black uppercase">Men</a>
            <a href="/products?category=kids" class="text-[11px] text-[#737373] hover:text-black uppercase">Kids</a>
          </div>
        </div>
        <div class="lg:w-1/3 text-center lg:text-right">
          <p class="text-[11px] font-bold mb-4 uppercase tracking-[0.2em]">Account</p>
          <div class="flex justify-center lg:justify-end gap-6">
            <a href="/profile" class="text-[11px] text-[#737373] hover:text-black uppercase tracking-wider">Profile</a>
            <a href="/orders" class="text-[11px] text-black font-bold uppercase tracking-wider border-b border-black">Orders</a>
            <a href="/logout" class="text-[11px] text-[#737373] hover:text-black uppercase tracking-wider">Logout</a>
          </div>
        </div>
      </div>
      <div class="mt-16 pt-8 border-t border-[#e0e0e0]">
        <p class="text-[10px] text-[#aaaaaa] tracking-[0.1em]">© 2026 MAISON. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <!-- Bottom Nav -->
  <%- include('../partials/bottomNav', { title }) %>
</body>
</html>
