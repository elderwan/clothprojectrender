<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | MAISON Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-100 text-zinc-900">
  <div id="sidebar-overlay" class="fixed inset-0 z-30 hidden bg-black/40 lg:hidden"></div>
  <%- include('../partials/adminSidebar', { activePage: 'categories' }) %>

  <div class="lg:pl-[260px]">
    <%- include('../partials/adminTopbar', { title }) %>

    <main class="px-5 py-5 lg:ml-10 lg:w-[1000px] lg:px-0 lg:py-8">
      <h1 class="font-serif text-[44px] leading-none">Category Dictionary</h1>
      <div class="mt-3 border-t border-zinc-300"></div>

      <% if (error) { %>
        <div class="mt-4 rounded border border-red-300 bg-red-50 px-4 py-3 text-sm text-red-700"><%= error %></div>
      <% } %>

      <form method="POST" action="<%= editingCategory ? ('/admin/settings/categories/' + editingCategory.id + '/edit') : '/admin/settings/categories' %>" class="mt-4 grid gap-3 rounded border border-zinc-300 bg-white p-4 md:grid-cols-4">
        <div>
          <label class="mb-1 block text-[12px] text-zinc-500">Name</label>
          <input class="h-10 w-full border border-zinc-300 px-3 text-[13px]" name="name" value="<%= editingCategory?.name || '' %>" required />
        </div>
        <div>
          <label class="mb-1 block text-[12px] text-zinc-500">Slug</label>
          <input class="h-10 w-full border border-zinc-300 px-3 text-[13px]" name="slug" value="<%= editingCategory?.slug || '' %>" required />
        </div>
        <div>
          <label class="mb-1 block text-[12px] text-zinc-500">Audience</label>
          <select class="h-10 w-full border border-zinc-300 px-3 text-[13px]" name="audience" required>
            <option value="women" <%= editingCategory?.audience === 'women' ? 'selected' : '' %>>Women</option>
            <option value="men" <%= editingCategory?.audience === 'men' ? 'selected' : '' %>>Men</option>
            <option value="kids" <%= editingCategory?.audience === 'kids' ? 'selected' : '' %>>Kids</option>
          </select>
        </div>
        <div class="flex items-end gap-2">
          <button class="inline-flex h-10 w-full items-center justify-center border border-black bg-black text-[12px] font-semibold text-white hover:bg-zinc-800" type="submit"><%= editingCategory ? 'UPDATE CATEGORY' : 'ADD CATEGORY' %></button>
          <% if (editingCategory) { %>
            <a href="/admin/settings/categories" class="inline-flex h-10 w-[120px] items-center justify-center border border-zinc-800 text-[12px] font-semibold hover:bg-zinc-900 hover:text-white">CANCEL</a>
          <% } %>
        </div>
      </form>

      <section class="mt-4 overflow-x-auto rounded border border-zinc-300 bg-white">
        <table class="min-w-full text-[13px]">
          <thead class="bg-zinc-200 text-left text-[12px] font-semibold">
            <tr>
              <th class="px-3 py-2">Name</th>
              <th class="px-3 py-2">Slug</th>
              <th class="px-3 py-2">Audience</th>
              <th class="px-3 py-2 text-right">Action</th>
            </tr>
          </thead>
          <tbody>
            <% if (!categories.length) { %>
              <tr><td colspan="4" class="px-3 py-4 text-zinc-500">No categories yet.</td></tr>
            <% } %>
            <% categories.forEach((c) => { %>
              <tr class="border-t border-zinc-200">
                <td class="px-3 py-2"><%= c.name %></td>
                <td class="px-3 py-2"><%= c.slug %></td>
                <td class="px-3 py-2 capitalize"><%= c.audience %></td>
                <td class="px-3 py-2 text-right">
                  <div class="flex justify-end gap-2">
                    <a href="/admin/settings/categories/<%= c.id %>/edit" class="inline-flex h-7 items-center border border-zinc-900 px-3 text-[12px] font-semibold hover:bg-zinc-900 hover:text-white">Edit</a>
                    <form method="POST" action="/admin/settings/categories/<%= c.id %>/delete" data-confirm="Delete this category? Products under it will become uncategorized.">
                      <button class="inline-flex h-7 items-center border border-zinc-900 px-3 text-[12px] font-semibold hover:bg-zinc-900 hover:text-white" type="submit">Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </section>
    </main>
  </div>
  <%- include('../partials/adminScripts') %>
</body>
</html>
