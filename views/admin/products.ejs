<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | MAISON Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-100 text-zinc-900">
  <div id="sidebar-overlay" class="fixed inset-0 z-30 hidden bg-black/40 lg:hidden"></div>
  <%- include('../partials/adminSidebar', { activePage: 'products' }) %>

  <div class="lg:pl-[260px]">
    <%- include('../partials/adminTopbar', { title }) %>

    <main class="px-5 py-5 lg:ml-10 lg:w-[1100px] lg:px-0 lg:py-8">
      <div class="flex items-center justify-between">
        <h1 class="font-serif text-[44px] leading-none">Product Management</h1>
        <a class="inline-flex h-10 w-[166px] items-center justify-center border border-black bg-black text-[12px] font-semibold text-white hover:bg-zinc-800" href="/admin/products/add">+ ADD PRODUCT</a>
      </div>
      <div class="mt-3 border-t border-zinc-300"></div>

      <form method="GET" action="/admin/products" class="mt-3 flex flex-wrap items-end gap-2">
        <div>
          <label class="block text-[12px] text-zinc-500">Keyword</label>
          <input
            name="q"
            value="<%= filters?.q || '' %>"
            class="mt-1 h-11 w-[300px] border border-zinc-300 bg-zinc-100 px-3 text-[13px]"
            type="text"
            placeholder="Name or description"
          />
        </div>
        <div>
          <label class="block text-[12px] text-zinc-500">Category</label>
          <select name="category_id" class="mt-1 h-11 w-[180px] border border-zinc-300 bg-zinc-100 px-3 text-[13px]">
            <option value="">All</option>
            <% categories.forEach((c) => { %>
              <option value="<%= c.id %>" <%= filters?.category_id === c.id ? 'selected' : '' %>><%= c.name %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label class="block text-[12px] text-zinc-500">Active</label>
          <select name="active" class="mt-1 h-11 w-[140px] border border-zinc-300 bg-zinc-100 px-3 text-[13px]">
            <option value="all" <%= (filters?.active || 'all') === 'all' ? 'selected' : '' %>>All</option>
            <option value="true" <%= filters?.active === 'true' ? 'selected' : '' %>>Yes</option>
            <option value="false" <%= filters?.active === 'false' ? 'selected' : '' %>>No</option>
          </select>
        </div>
        <button class="inline-flex h-11 items-center border border-black bg-black px-4 text-[12px] font-semibold text-white hover:bg-zinc-800" type="submit">Search</button>
        <a class="inline-flex h-11 items-center border border-zinc-400 px-4 text-[12px] font-semibold text-zinc-700 hover:bg-zinc-200" href="/admin/products">Reset</a>
      </form>

      <section class="mt-2 overflow-x-auto">
        <table class="min-w-full text-[13px]">
          <thead class="bg-zinc-200 text-left text-[12px] font-semibold">
            <tr>
              <th class="px-4 py-3">Product</th>
              <th class="px-4 py-3">Category</th>
              <th class="px-4 py-3">Price</th>
              <th class="px-4 py-3">Stock</th>
              <th class="px-4 py-3">Active</th>
              <th class="px-4 py-3 text-right">Actions</th>
            </tr>
          </thead>
          <tbody>
          <% if (!products.length) { %>
            <tr><td colspan="6" class="px-4 py-6 text-zinc-500">No products found.</td></tr>
          <% } %>
          <% products.forEach((p) => { %>
            <tr class="border-t border-zinc-200">
              <td class="px-4 py-3">
                <div class="flex items-center gap-4">
                  <% if (p.primary_image) { %>
                    <img src="<%= p.primary_image %>" alt="<%= p.name %>" class="h-11 w-[50px] border border-zinc-200 object-cover" />
                  <% } else { %>
                    <span class="h-11 w-[50px] border border-zinc-200 bg-zinc-200"></span>
                  <% } %>
                  <p class="font-medium"><%= p.name %></p>
                </div>
              </td>
              <td class="px-4 py-3"><%= p.category || '-' %></td>
              <td class="px-4 py-3">$<%= Number(p.price || 0).toFixed(2) %></td>
              <td class="px-4 py-3"><%= p.stock_quantity %></td>
              <td class="px-4 py-3"><%= p.is_active ? 'Yes' : 'No' %></td>
              <td class="px-4 py-3 text-right">
                <div class="flex justify-end gap-2">
                  <a class="inline-flex h-[30px] w-16 items-center justify-center border border-zinc-900 text-[12px] font-semibold hover:bg-zinc-900 hover:text-white" href="/admin/products/<%= p.id %>/edit">Edit</a>
                  <form method="POST" action="/admin/products/<%= p.id %>/delete" data-confirm="Delete this product?">
                    <button class="inline-flex h-[30px] w-[72px] items-center justify-center border border-zinc-900 text-[12px] font-semibold hover:bg-zinc-900 hover:text-white" type="submit">Delete</button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
          </tbody>
        </table>
      </section>
    </main>
  </div>
  <%- include('../partials/adminScripts') %>
</body>
</html>
