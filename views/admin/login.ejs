<!doctype html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>
    <%= title %> | MAISON
  </title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="min-h-screen bg-zinc-100 text-zinc-900">
  <main class="mx-auto w-full max-w-[1440px] px-4 py-20">
    <section class="mx-auto w-full max-w-[480px] border border-zinc-300 bg-zinc-100 px-7 py-9">
      <h1 class="text-center font-serif text-[44px] leading-none">MAISON</h1>
      <p class="mt-2 text-center text-[12px] text-zinc-500">Back Office</p>
      <div class="mt-3 border-t border-zinc-300"></div>

      <h2 class="mt-4 text-[15px] font-semibold tracking-tight">ADMINISTRATOR SIGN IN</h2>

      <% if (error) { %>
        <div class="mt-3 border border-red-300 bg-red-50 px-3 py-2 text-[13px] text-red-700">
          <%= error %>
        </div>
        <% } %>

          <form class="mt-4 space-y-5" method="POST" action="/admin/login">
            <div>
              <label class="mb-2 block text-[12px] text-zinc-500">Admin Email</label>
              <input class="h-11 w-full border border-zinc-300 bg-zinc-100 px-3 text-[13px]" type="email" name="email"
                required />
            </div>
            <div>
              <label class="mb-2 block text-[12px] text-zinc-500">Password</label>
              <input class="h-11 w-full border border-zinc-300 bg-zinc-100 px-3 text-[13px]" type="password"
                name="password" required />
            </div>
            <button class="h-[52px] w-full border border-black bg-black text-[13px] font-semibold text-white"
              type="submit">ACCESS DASHBOARD</button>
          </form>

          <div class="mt-5 border-t border-zinc-300"></div>
          <a class="mt-4 inline-block text-[13px] text-zinc-500 hover:text-zinc-900" href="/">Back to main site</a>
    </section>
  </main>
</body>

</html>