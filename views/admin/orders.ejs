<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | MAISON Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-100 text-zinc-900">
  <div id="sidebar-overlay" class="fixed inset-0 z-30 hidden bg-black/40 lg:hidden"></div>
  <%- include('../partials/adminSidebar', { activePage: 'orders' }) %>

  <div class="lg:pl-[260px]">
    <%- include('../partials/adminTopbar', { title }) %>

    <main class="px-5 py-5 lg:ml-10 lg:w-[1100px] lg:px-0 lg:py-8">
      <h1 class="font-serif text-[28px] sm:text-[32px] lg:text-[44px] leading-none">Order Management</h1>
      <div class="mt-3 border-t border-zinc-300"></div>

      <form method="GET" action="/admin/orders" class="mt-3 grid gap-2 md:grid-cols-3 lg:grid-cols-4">
        <div>
          <label class="block text-[12px] text-zinc-500">Order #</label>
          <input name="order_no" value="<%= filters?.order_no || '' %>" class="mt-1 h-10 w-full sm:w-auto border border-zinc-300 bg-zinc-100 px-3 text-[13px]" type="text" placeholder="UUID / partial id" />
        </div>
        <div>
          <label class="block text-[12px] text-zinc-500">Customer</label>
          <input name="customer" value="<%= filters?.customer || '' %>" class="mt-1 h-10 w-full border border-zinc-300 bg-zinc-100 px-3 text-[13px]" type="text" placeholder="Name or email" />
        </div>
        <div>
          <label class="block text-[12px] text-zinc-500">Status</label>
          <select name="status" class="mt-1 h-10 w-full border border-zinc-300 bg-zinc-100 px-3 text-[13px]">
            <% const statuses = ['all', 'pending', 'processing', 'shipped', 'delivered', 'cancelled']; %>
            <% statuses.forEach((s) => { %>
              <option value="<%= s %>" <%= (filters?.status || 'all') === s ? 'selected' : '' %>><%= s.charAt(0).toUpperCase() + s.slice(1) %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label class="block text-[12px] text-zinc-500">Date From</label>
          <input name="date_from" value="<%= filters?.date_from || '' %>" class="mt-1 h-10 w-full border border-zinc-300 bg-zinc-100 px-3 text-[13px]" type="date" />
        </div>
        <div>
          <label class="block text-[12px] text-zinc-500">Date To</label>
          <input name="date_to" value="<%= filters?.date_to || '' %>" class="mt-1 h-10 w-full border border-zinc-300 bg-zinc-100 px-3 text-[13px]" type="date" />
        </div>
        <div>
          <label class="block text-[12px] text-zinc-500">Min Total</label>
          <input name="min_total" value="<%= filters?.min_total ?? '' %>" class="mt-1 h-10 w-full border border-zinc-300 bg-zinc-100 px-3 text-[13px]" type="number" min="0" step="0.01" />
        </div>
        <div>
          <label class="block text-[12px] text-zinc-500">Max Total</label>
          <input name="max_total" value="<%= filters?.max_total ?? '' %>" class="mt-1 h-10 w-full border border-zinc-300 bg-zinc-100 px-3 text-[13px]" type="number" min="0" step="0.01" />
        </div>
        <div class="flex items-end gap-2">
          <button class="inline-flex h-10 items-center border border-black bg-black px-4 text-[12px] font-semibold text-white hover:bg-zinc-800" type="submit">Search</button>
          <a class="inline-flex h-10 items-center border border-zinc-400 px-4 text-[12px] font-semibold text-zinc-700 hover:bg-zinc-200" href="/admin/orders">Reset</a>
        </div>
      </form>

      <section class="mt-3 overflow-x-auto">
        <table class="min-w-full text-[13px]">
          <thead class="bg-zinc-200 text-left text-[12px] font-semibold">
          <tr>
            <th class="px-2 py-2">Order #</th>
            <th class="px-2 py-2 hidden sm:table-cell">Customer</th>
            <th class="px-2 py-2 hidden md:table-cell">Date</th>
            <th class="px-2 py-2 hidden sm:table-cell">Items</th>
            <th class="px-2 py-2">Total</th>
            <th class="px-2 py-2">Status</th>
            <th class="px-2 py-2 text-right">Action</th>
          </tr>
          </thead>
          <tbody>
          <% if (!orders.length) { %>
            <tr><td colspan="7" class="px-4 py-6 text-zinc-500">No orders found.</td></tr>
          <% } %>
          <% orders.forEach((o, idx) => { %>
            <tr class="border-t border-zinc-200">
              <td class="px-2 py-3">#<%= String(o.id).slice(0, 6) %></td>
              <td class="px-2 py-3 hidden sm:table-cell"><%= o.user_name || o.user_email || 'Customer Name' %></td>
              <td class="px-2 py-3 hidden md:table-cell"><%= o.created_at ? new Intl.DateTimeFormat('sv-SE').format(new Date(o.created_at)) : '2026-01-01' %></td>
              <td class="px-2 py-3 hidden sm:table-cell"><%= o.items?.length ?? (idx + 1) %></td>
              <td class="px-2 py-3">$<%= Number(o.total_amount || 0).toFixed(2) %></td>
              <td class="px-2 py-3"><%= o.status %></td>
              <td class="px-2 py-2 text-right"><a class="inline-flex h-7 w-[74px] items-center justify-center border border-zinc-900 text-[12px] font-semibold hover:bg-zinc-900 hover:text-white" href="/admin/orders/<%= o.id %>">View</a></td>
            </tr>
          <% }) %>
          </tbody>
        </table>
      </section>
    </main>
  </div>
  <%- include('../partials/adminScripts') %>
</body>
</html>
