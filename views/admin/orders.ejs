<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | MAISON Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-100 text-zinc-900">
  <div id="sidebar-overlay" class="fixed inset-0 z-30 hidden bg-black/40 lg:hidden"></div>
  <%- include('../partials/adminSidebar', { activePage: 'orders' }) %>

  <div class="lg:pl-[260px]">
    <%- include('../partials/adminTopbar', { title }) %>

    <main class="px-5 py-5 lg:ml-10 lg:w-[1100px] lg:px-0 lg:py-8">
      <h1 class="font-serif text-[44px] leading-none">Order Management</h1>
      <div class="mt-3 border-t border-zinc-300"></div>

      <div class="mt-3 flex flex-wrap gap-2">
        <% const tabs = ['all', 'processing', 'shipped', 'delivered', 'cancelled']; %>
        <% tabs.forEach((s) => { %>
          <a class="inline-flex h-9 items-center border px-3 text-[12px] <%= activeStatus === s ? 'border-black bg-black text-white' : 'border-zinc-300 bg-zinc-100 hover:border-zinc-900' %>" href="/admin/orders?status=<%= s %>"><%= s.charAt(0).toUpperCase() + s.slice(1) %></a>
        <% }) %>
      </div>

      <section class="mt-3 overflow-x-auto">
        <table class="min-w-full text-[13px]">
          <thead class="bg-zinc-200 text-left text-[12px] font-semibold">
          <tr>
            <th class="px-2 py-2">Order #</th>
            <th class="px-2 py-2">Customer</th>
            <th class="px-2 py-2">Date</th>
            <th class="px-2 py-2">Items</th>
            <th class="px-2 py-2">Total</th>
            <th class="px-2 py-2">Status</th>
            <th class="px-2 py-2 text-right">Action</th>
          </tr>
          </thead>
          <tbody>
          <% if (!orders.length) { %>
            <tr><td colspan="7" class="px-4 py-6 text-zinc-500">No orders found.</td></tr>
          <% } %>
          <% orders.forEach((o, idx) => { %>
            <tr class="border-t border-zinc-200">
              <td class="px-2 py-3">#<%= String(o.id).slice(0, 6) %></td>
              <td class="px-2 py-3"><%= o.user_name || o.user_email || 'Customer Name' %></td>
              <td class="px-2 py-3"><%= o.created_at ? new Date(o.created_at).toLocaleDateString('en-US', { month: 'short', year: 'numeric' }) : 'Jan 2026' %></td>
              <td class="px-2 py-3"><%= o.items?.length ?? (idx + 1) %></td>
              <td class="px-2 py-3">$<%= Number(o.total_amount || 0).toFixed(2) %></td>
              <td class="px-2 py-3"><%= o.status %></td>
              <td class="px-2 py-2 text-right"><a class="inline-flex h-7 w-[74px] items-center justify-center border border-zinc-900 text-[12px] font-semibold hover:bg-zinc-900 hover:text-white" href="/admin/orders/<%= o.id %>">View</a></td>
            </tr>
          <% }) %>
          </tbody>
        </table>
      </section>
    </main>
  </div>
  <%- include('../partials/adminScripts') %>
</body>
</html>
