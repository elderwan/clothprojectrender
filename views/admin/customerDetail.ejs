<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | MAISON Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-100 text-zinc-900">
  <div id="sidebar-overlay" class="fixed inset-0 z-30 hidden bg-black/40 lg:hidden"></div>
  <%- include('../partials/adminSidebar', { activePage: 'customers' }) %>

  <div class="lg:pl-64">
    <%- include('../partials/adminTopbar', { title }) %>

    <main class="mx-auto w-full max-w-4xl px-4 py-6 lg:px-8">
      <section class="space-y-3">
        <article class="rounded border border-zinc-200 bg-white p-4">
          <p class="text-xs text-zinc-500">Full Name</p>
          <p class="mt-1 font-semibold"><%= customer.full_name %></p>
        </article>
        <article class="rounded border border-zinc-200 bg-white p-4">
          <p class="text-xs text-zinc-500">Email</p>
          <p class="mt-1"><%= customer.email %></p>
        </article>
        <article class="rounded border border-zinc-200 bg-white p-4">
          <p class="text-xs text-zinc-500">Phone</p>
          <p class="mt-1"><%= customer.phone || '-' %></p>
        </article>
        <article class="rounded border border-zinc-200 bg-white p-4">
          <p class="text-xs text-zinc-500">Role</p>
          <p class="mt-1"><%= customer.role %></p>
        </article>
        <article class="rounded border border-zinc-200 bg-white p-4">
          <p class="text-xs text-zinc-500">Status</p>
          <p class="mt-1"><%= customer.is_active ? 'Active' : 'Disabled' %></p>
        </article>
        <article class="rounded border border-zinc-200 bg-white p-4">
          <p class="text-xs text-zinc-500">Created At</p>
          <p class="mt-1"><%= customer.created_at ? new Date(customer.created_at).toLocaleString() : '-' %></p>
        </article>
      </section>
    </main>
  </div>
  <%- include('../partials/adminScripts') %>
</body>
</html>
