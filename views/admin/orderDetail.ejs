<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | MAISON Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-100 text-zinc-900">
  <div id="sidebar-overlay" class="fixed inset-0 z-30 hidden bg-black/40 lg:hidden"></div>
  <%- include('../partials/adminSidebar', { activePage: 'orders' }) %>

  <div class="lg:pl-64">
    <%- include('../partials/adminTopbar', { title }) %>

    <main class="mx-auto w-full max-w-7xl px-4 py-6 lg:px-8">
      <section class="grid gap-4 md:grid-cols-3">
        <article class="rounded border border-zinc-200 bg-white p-4">
          <p class="text-xs text-zinc-500">Order ID</p>
          <p class="mt-2 break-all font-semibold"><%= order.id %></p>
        </article>
        <article class="rounded border border-zinc-200 bg-white p-4">
          <p class="text-xs text-zinc-500">Customer</p>
          <p class="mt-2 font-semibold"><%= order.user_name || order.user_email || 'Unknown' %></p>
        </article>
        <article class="rounded border border-zinc-200 bg-white p-4">
          <p class="text-xs text-zinc-500">Total</p>
          <p class="mt-2 font-semibold">$<%= Number(order.total_amount || 0).toFixed(2) %></p>
        </article>
      </section>

      <section class="mt-4 rounded border border-zinc-200 bg-white p-4">
        <form class="flex flex-wrap items-center gap-3" method="POST" action="/admin/orders/<%= order.id %>/status">
          <label class="text-sm text-zinc-600">Status</label>
          <select class="h-10 min-w-44 border border-zinc-300 px-3" name="status">
            <% ['pending','processing','shipped','delivered','cancelled'].forEach((s) => { %>
              <option value="<%= s %>" <%= order.status === s ? 'selected' : '' %>><%= s %></option>
            <% }) %>
          </select>
          <button type="submit" class="inline-flex h-10 items-center border border-black bg-black px-4 text-sm font-semibold text-white hover:bg-zinc-800">Update Status</button>
        </form>
      </section>

      <section class="mt-6 overflow-x-auto rounded border border-zinc-200 bg-white">
        <table class="min-w-full text-sm">
          <thead class="bg-zinc-50 text-left text-xs uppercase tracking-wide text-zinc-500">
            <tr>
              <th class="px-4 py-3">Product</th>
              <th class="px-4 py-3">Qty</th>
              <th class="px-4 py-3">Size</th>
              <th class="px-4 py-3">Unit Price</th>
              <th class="px-4 py-3">Subtotal</th>
            </tr>
          </thead>
          <tbody>
          <% if (!order.items?.length) { %>
            <tr><td colspan="5" class="px-4 py-6 text-zinc-500">No line items.</td></tr>
          <% } %>
          <% (order.items || []).forEach((i) => { %>
            <tr class="border-t border-zinc-200">
              <td class="px-4 py-3"><%= i.product_name || i.product_id %></td>
              <td class="px-4 py-3"><%= i.quantity %></td>
              <td class="px-4 py-3"><%= i.size || '-' %></td>
              <td class="px-4 py-3">$<%= Number(i.unit_price || 0).toFixed(2) %></td>
              <td class="px-4 py-3">$<%= Number((i.unit_price || 0) * (i.quantity || 0)).toFixed(2) %></td>
            </tr>
          <% }) %>
          </tbody>
        </table>
      </section>
    </main>
  </div>
  <%- include('../partials/adminScripts') %>
</body>
</html>
